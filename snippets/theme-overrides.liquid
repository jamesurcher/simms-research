{% comment %}
  Brand overrides for Simms Research.
  Targets Horizon defaults that conflict with the design-implementation-brief
  (e.g. icon-only quick-add CTA → labeled pill, hover-only reveals, etc.).

  Render after `custom-fonts` in layout/theme.liquid so source order wins.
{% endcomment %}

{% style %}
  /* ---- Homepage transparent header ------------------------------------
     Horizon subtracts header height from full-screen heroes. When the
     homepage header is transparent, the hero already sits underneath it, so
     removing the offset prevents the white band at the bottom of the fold. */

  body:has(> #header-group > .header-section > #header-component[transparent])
    .content-for-layout > .shopify-section:first-child .hero-wrapper:first-child {
    --hero-height-offset: 0px;
  }

  body:has(> #header-group > .header-section > #header-component[transparent])
    .content-for-layout > .shopify-section:first-child .hero {
    min-height: var(--hero-min-height, 100svh) !important;
  }

  /* ---- Homepage product-list heading -----------------------------------
     Replace the default chunky rich-text treatment with the same restrained
     editorial system used across the research and lab sections. */

  [class*='__text_MEWCAN'] p {
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin: 0;
  }

  [class*='__product_list_text_Bd9pVh'] h2 {
    font-family: var(--font-heading--family);
    font-size: clamp(2.25rem, 3vw, 2.5rem);
    font-weight: var(--font-heading--weight);
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: var(--color-foreground-heading);
    margin: 0;
  }

  /* ---- Legal pages ------------------------------------------------------
     Keep policy pages deliberately plain and document-like. The page copy was
     pasted with external utility classes, so this neutralizes that formatting
     without changing the text. */

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    .section-content-wrapper {
    max-width: min(46rem, calc(100% - 2rem));
    margin-inline: auto;
    gap: 0;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    .section-content-wrapper
    > .text-block:first-child {
    display: none;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    .shopify-block.rte {
    width: 100%;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter {
    display: block;
    font-family: Arial, Helvetica, sans-serif;
    color: #111;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    :where(h1, h2, h3, h4, p, ul, ol) {
    margin: 0;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    > [class*='text-center'] {
    margin-block: 0 2rem;
    text-align: left;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    h1 {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0;
    color: #111;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    h1
    + p {
    margin-block-start: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #444;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    h2 {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0;
    color: #111;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    h3 {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: 0;
    color: #111;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    p,
  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    li {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #222;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    p
    + p {
    margin-block-start: 1rem;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    ul,
  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    ol {
    padding-inline-start: 1.5rem;
    margin-block-start: 0.75rem;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    li
    + li {
    margin-block-start: 0.25rem;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    section {
    padding-block-start: 0;
    margin-block-start: 1.75rem;
    border: 0;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    section
    > *
    + * {
    margin-block-start: 0.75rem;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    :is([class*='shadcn-card'], [class*='border'], [class*='bg-'], [class*='rounded'], [class*='shadow']) {
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    :is([class*='shadcn-card'], [class*='border'], [class*='bg-'], [class*='rounded'], [class*='shadow'])
    + * {
    margin-block-start: 1.25rem;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    [class*='flex'] {
    display: block;
  }

  :is(
      .main-page--terms-conditions,
      .main-page--privacy-policy,
      .main-page--refund-return,
      .main-page--shipping-policy
    )
    rte-formatter
    svg {
    display: none;
  }

  @media screen and (max-width: 749px) {
    body:has(> #header-group > .header-section > #header-component[transparent])
      .content-for-layout > .shopify-section:first-child .hero__media {
      object-position: 30% center;
    }

    body:has(> #header-group > .header-section > #header-component[transparent])
      .content-for-layout > .shopify-section:first-child .hero__content-wrapper
      > .group-block:first-child {
      position: absolute;
      inset-block-start: clamp(8.75rem, 17svh, 10.25rem);
      inset-inline: 0;
      width: 100%;
      height: auto;
      z-index: var(--layer-flat);
    }

    body:has(> #header-group > .header-section > #header-component[transparent])
      .content-for-layout > .shopify-section:first-child .hero__content-wrapper
      > .group-block:first-child
      > .group-block-content {
      height: auto;
      justify-content: flex-start;
    }
  }

  #header-component[transparent='not-sticky']:not([data-sticky-state='active']):not(:hover):not(:focus-within)
    :is(.menu-list__link, .header-actions__action, .account-button__icon, .account-button__text) {
    color: rgb(255 255 255 / 1);
  }

  #header-component[transparent='not-sticky']:not([data-sticky-state='active']):not(:hover):not(:focus-within)
    .header__row {
    --button-color: rgb(255 255 255 / 1);
    --color-account-icon: rgb(255 255 255 / 1);
  }

  /* ---- Product card: labeled CTA pill ----------------------------------
     Default Horizon quick-add is a 36px icon overlay positioned over the
     image, only revealed on hover. Per brief §3 move 4, replace with an
     always-visible labeled CTA below the card content. */

  .product-grid__card .quick-add {
    position: static;
    inset: auto;
    pointer-events: auto;
  }

  product-card .quick-add__product-form-component .shopify-product-form {
    display: block;
    width: 100%;
  }

  product-card add-to-cart-component {
    width: 100%;
  }

  product-card .quick-add__button,
  product-card .quick-add__button.add-to-cart-button {
    display: flex;
    position: static;
    opacity: 1;
    width: 100%;
    height: auto;
    min-height: 0;
    padding: 0;
    border-radius: 999px;
    border: 1px solid currentColor;
    backdrop-filter: none;
    background: transparent;
    margin-block-start: 0.75rem;
  }

  product-card .quick-add__button .add-to-cart-text {
    background: transparent;
    border-radius: 999px;
    width: 100%;
    height: auto;
    padding: 0.875rem 1rem;
    justify-content: center;
    gap: 0.5rem;
  }

  product-card .quick-add__button .add-to-cart-icon {
    display: none;
  }

  product-card .quick-add__button .add-to-cart-text__content {
    grid-template-columns: 1fr;
    width: 100%;
  }

  product-card .quick-add__button .add-to-cart-text__content > span {
    min-width: 0;
    width: 100%;
  }

  product-card .quick-add__button .add-to-cart-text__content span span {
    opacity: 1;
    translate: 0 0;
    filter: blur(0);
    padding-right: 0;
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  product-card .quick-add__button .is-visually-hidden-mobile,
  product-card .quick-add__button .add-to-cart-text__content.is-visually-hidden-mobile {
    position: static !important;
    width: auto !important;
    height: auto !important;
    overflow: visible !important;
    clip: auto !important;
    white-space: normal !important;
  }

  product-card .quick-add__button:hover {
    scale: 1;
    background: var(--color-primary-button-hover-background);
    border-color: var(--color-primary-button-hover-border);
  }

  product-card .quick-add__button:hover .add-to-cart-text__content span span {
    color: var(--color-primary-button-hover-text);
  }

  /* Card content stretches and CTA sticks to bottom */
  .product-grid__card {
    align-items: stretch;
  }

  product-card .product-card__content {
    height: 100%;
  }

  product-card .product-card__content > quick-add-component,
  product-card .product-card__content > .quick-add {
    margin-block-start: auto;
  }

  /* Round the IMAGE area only, not the gallery box.
     The gallery's height grows to include our static quick-add pill,
     so its rounded bottom corners end up below the visible image.
     Move the radius onto slideshow-container (image-only), and let
     the gallery itself flow without clipping. */
  .product-card .card-gallery {
    overflow: visible;
    border-radius: 0;
  }

  .product-card .card-gallery slideshow-container {
    overflow: hidden;
    border-radius: var(--border-radius, 16px);
  }

  /* Restore Horizon's add/choose toggle.
     My .quick-add__button display:flex rule above ties Horizon's default
     hide rules on specificity, and source order would let display:flex
     win — so re-assert the hide logic at the end of the file with
     equivalent specificity but later source order. */
  product-card [data-quick-add-button='choose'] add-to-cart-component,
  product-card [data-quick-add-button='choose'] .quick-add__button--add {
    display: none;
  }

  product-card [data-quick-add-button='add'] .quick-add__button--choose {
    display: none;
  }

  product-card [data-quick-add-button='add'] add-to-cart-component {
    display: block;
  }

  @media screen and (min-width: 1200px) {
    .product-information__media media-gallery {
      max-width: min(35rem, 42vw);
      margin-inline-start: auto;
    }

    .product-information__media .product-media-container,
    .product-information__media .product-media {
      max-height: min(72dvh, 46rem);
    }

    .product-information__media .product-media img {
      max-height: min(72dvh, 46rem);
      object-fit: contain;
    }
  }

  /* ---- PDP research profile / technical specs -------------------------
     Amino-inspired content hierarchy, translated into the sparse Simms
     system: mono labels, quiet rules, no icon badges, no marketing chrome. */

  .product-research-details {
    display: block;
    width: 100%;
  }

  .product-research-details__section {
    width: 100%;
  }

  .product-research-details__section + .product-research-details__section {
    margin-block-start: 1.45rem;
    padding-block-start: 1.35rem;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .product-research-details__section + .product-research-details__section--specs {
    border-top: 0;
  }

  .product-research-details__eyebrow {
    margin: 0 0 0.78rem;
    color: rgb(var(--color-foreground-rgb) / 0.48);
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: var(--font-mono--weight);
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .product-research-details__eyebrow-icon {
    display: inline-flex;
    align-items: center;
    width: 0.95rem;
    height: 0.95rem;
    color: currentColor;
  }

  .product-research-details__eyebrow-icon svg {
    width: 100%;
    height: 100%;
  }

  .product-research-details__lead,
  .product-research-details__body {
    display: block;
    color: rgb(var(--color-foreground-rgb) / 0.78);
  }

  .product-research-details__lead {
    font-size: 1.02rem;
    line-height: 1.46;
  }

  .product-research-details__body {
    margin-block-start: 0.85rem;
    color: rgb(var(--color-foreground-rgb) / 0.68);
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .product-research-details__lead :is(p, ul, ol),
  .product-research-details__body :is(p, ul, ol) {
    margin-block: 0;
  }

  .product-research-details__body :is(p, ul, ol) + :is(p, ul, ol) {
    margin-block-start: 0.78rem;
  }

  .product-research-details__spec-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    margin: 0;
  }

  .product-research-details__spec {
    min-width: 0;
    padding: 0.82rem 0.9rem 0.82rem 0;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .product-research-details__spec:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .product-research-details__spec dt {
    margin: 0 0 0.28rem;
    color: rgb(var(--color-foreground-rgb) / 0.42);
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: var(--font-mono--weight);
    letter-spacing: 0.13em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .product-research-details__spec dd {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.76);
    font-family: var(--font-mono--family);
    font-size: 0.875rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .product-research-details__note {
    color: rgb(var(--color-foreground-rgb) / 0.68);
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  /* ---- PDP batch verification / COA module -----------------------------
     Modeled after Instant Peptides' lab-result card, translated into the
     lighter Simms system: mono data, hairline dividers, restrained verified
     green, and no generic trust-badge clutter. */

  batch-verification[hidden] {
    display: none;
  }

  .batch-verification {
    display: block;
    width: 100%;
  }

  .batch-verification__panel {
    overflow: hidden;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 16px;
    background: rgb(var(--color-background-rgb) / 0.72);
  }

  .batch-verification__summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    align-items: center;
    gap: 0.75rem;
    min-height: 4.25rem;
    padding: 1rem 1.125rem;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    cursor: pointer;
    list-style: none;
  }

  .batch-verification__summary::-webkit-details-marker {
    display: none;
  }

  .batch-verification__summary-main {
    display: inline-flex;
    align-items: center;
    gap: 0.62rem;
    min-width: 0;
  }

  .batch-verification__status-dot {
    position: relative;
    display: inline-flex;
    width: 1.2rem;
    height: 1.2rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid #009b57;
    border-radius: 999px;
  }

  .batch-verification__status-dot::after {
    content: "";
    width: 0.28rem;
    height: 0.45rem;
    border: solid #009b57;
    border-width: 0 1.5px 1.5px 0;
    transform: translateY(-0.035rem) rotate(45deg);
  }

  .batch-verification__title,
  .batch-verification__previous-title,
  .batch-verification__metric dt {
    font-family: var(--font-mono--family);
    font-weight: var(--font-mono--weight);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .batch-verification__title {
    overflow: hidden;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-size: 0.8125rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .batch-verification__purity-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.38rem 0.75rem;
    border: 1px solid rgb(0 155 87 / 0.42);
    border-radius: 999px;
    color: #009b57;
    font-family: var(--font-mono--family);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
  }

  .batch-verification__chevron {
    width: 0.55rem;
    height: 0.55rem;
    border: solid rgb(var(--color-foreground-rgb) / 0.48);
    border-width: 1.5px 1.5px 0 0;
    transform: translateY(0.12rem) rotate(-45deg);
    transition: transform 180ms ease;
  }

  .batch-verification__panel:not([open]) .batch-verification__summary {
    border-bottom-color: transparent;
  }

  .batch-verification__panel:not([open]) .batch-verification__chevron {
    transform: translateY(-0.08rem) rotate(135deg);
  }

  .batch-verification__body {
    padding: 1.25rem 1.125rem 1.125rem;
  }

  .batch-verification__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem 1rem;
    margin: 0;
  }

  .batch-verification__metric {
    min-width: 0;
  }

  .batch-verification__metric dt {
    margin: 0 0 0.36rem;
    color: rgb(var(--color-foreground-rgb) / 0.42);
    font-size: 0.6875rem;
    line-height: 1.2;
  }

  .batch-verification__metric dd {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.74);
    font-family: var(--font-mono--family);
    font-size: 1rem;
    line-height: 1.1;
  }

  .batch-verification__metric dd .batch-verification__delta {
    display: inline-block;
    position: relative;
    inset-inline-start: -0.02rem;
    margin-inline-start: 0.1rem;
    color: #009b57;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transform: translateY(-0.03rem);
  }

  .batch-verification__value--verified,
  .batch-verification__previous-purity {
    color: #009b57 !important;
  }

  .batch-verification__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.7rem;
    margin-block-start: 1.35rem;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    border-radius: 12px;
    color: rgb(var(--color-foreground-rgb) / 0.74);
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background 180ms ease;
  }

  .batch-verification__button:hover {
    border-color: rgb(var(--color-foreground-rgb) / 0.48);
    background: rgb(var(--color-foreground-rgb) / 0.03);
    color: var(--color-foreground);
  }

  .batch-verification__previous {
    margin-block-start: 1.35rem;
    padding-block-start: 1.25rem;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .batch-verification__previous-title {
    margin: 0 0 0.85rem;
    color: rgb(var(--color-foreground-rgb) / 0.42);
    font-size: 0.6875rem;
  }

  .batch-verification__previous-list {
    display: grid;
    gap: 0.62rem;
  }

  .batch-verification__previous-row {
    display: grid;
    grid-template-columns: minmax(7.2rem, 1.2fr) minmax(4.5rem, 0.7fr) minmax(5.5rem, 0.8fr) minmax(6.4rem, 1fr) auto;
    gap: 0.7rem;
    align-items: baseline;
    color: rgb(var(--color-foreground-rgb) / 0.46);
    font-family: var(--font-mono--family);
    font-size: 0.8125rem;
    line-height: 1.35;
  }

  .batch-verification__previous-batch {
    color: rgb(var(--color-foreground-rgb) / 0.54);
  }

  .batch-verification__previous-row a,
  .batch-verification__footer a {
    color: rgb(var(--color-foreground-rgb) / 0.56);
    text-decoration-color: currentColor;
    text-underline-offset: 0.22em;
  }

  .batch-verification__previous-row a:hover,
  .batch-verification__footer a:hover {
    color: var(--color-foreground);
  }

  .batch-verification__footer {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-block-start: 1.25rem;
    padding-block-start: 1rem;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font-size: 0.8125rem;
  }

  .batch-verification__footer span {
    width: 0.45rem;
    height: 0.45rem;
    flex: 0 0 auto;
    border-radius: 999px;
    background: #009b57;
  }

  .batch-verification__footer p {
    margin: 0;
  }

  .batch-verification__footer a {
    margin-inline-start: auto;
  }

  .batch-verification__dialog {
    width: min(92vw, 64rem);
    max-width: none;
    max-height: 90dvh;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.16);
    border-radius: 18px;
    background: rgb(var(--color-background-rgb) / 0.98);
    color: var(--color-foreground);
  }

  .batch-verification__dialog::backdrop {
    background: rgb(0 0 0 / 0.62);
    backdrop-filter: blur(10px);
  }

  .batch-verification__dialog-shell {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    max-height: 90dvh;
  }

  .batch-verification__dialog-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .batch-verification__dialog-header p {
    flex: 1;
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-family: var(--font-mono--family);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .batch-verification__dialog-link {
    color: rgb(var(--color-foreground-rgb) / 0.62);
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    text-decoration-color: currentColor;
    text-underline-offset: 0.24em;
    white-space: nowrap;
  }

  .batch-verification__dialog-link:hover {
    color: var(--color-foreground);
  }

  .batch-verification__dialog-link[hidden] {
    display: none;
  }

  .batch-verification__dialog-close {
    display: inline-grid;
    width: 2.15rem;
    height: 2.15rem;
    margin-inline-start: 0;
    place-items: center;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
    border-radius: 999px;
    background: transparent;
    color: rgb(var(--color-foreground-rgb) / 0.72);
    cursor: pointer;
    font-size: 1.25rem;
    line-height: 1;
  }

  .batch-verification__dialog-close:hover {
    border-color: rgb(var(--color-foreground-rgb) / 0.32);
    color: var(--color-foreground);
  }

  .batch-verification__dialog-body {
    min-height: 0;
    overflow: auto;
    padding: 0;
    background: rgb(var(--color-background-rgb) / 1);
  }

  .batch-verification__dialog-body [hidden] {
    display: none !important;
  }

  .batch-verification__dialog-body img,
  .batch-verification__dialog-frame {
    display: block;
    width: 100%;
    margin-inline: auto;
    border-radius: 0;
    box-shadow: none;
  }

  .batch-verification__dialog-body img {
    height: auto;
  }

  .batch-verification__dialog-frame {
    height: min(78dvh, 64rem);
    min-height: 32rem;
    border: 0;
    background: #fff;
  }

  @media screen and (min-width: 990px) {
    .batch-verification__metrics {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .product-research-details__section + .product-research-details__section {
      margin-block-start: 1.25rem;
      padding-block-start: 1.15rem;
    }

    .product-research-details__spec-grid {
      grid-template-columns: 1fr;
    }

    .product-research-details__spec {
      padding-inline-end: 0;
    }

    .batch-verification__summary {
      grid-template-columns: minmax(0, 1fr) auto;
    }

    .batch-verification__purity-pill {
      justify-self: start;
      grid-column: 1 / -1;
      margin-inline-start: 1.9rem;
    }

    .batch-verification__chevron {
      grid-column: 2;
      grid-row: 1;
    }

    .batch-verification__previous-row {
      grid-template-columns: 1fr auto;
    }

    .batch-verification__previous-row > span:last-child {
      grid-column: 1 / -1;
      justify-self: start;
    }

    .batch-verification__footer {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .batch-verification__footer a {
      width: 100%;
      margin-inline-start: 1rem;
    }

    .batch-verification__dialog {
      width: 100vw;
      height: 100dvh;
      max-height: 100dvh;
      border: 0;
      border-radius: 0;
    }

    .batch-verification__dialog-shell {
      max-height: 100dvh;
    }

    .batch-verification__dialog-header {
      padding-inline: 0.875rem;
    }

    .batch-verification__dialog-header p {
      font-size: 0.6875rem;
    }

    .batch-verification__dialog-body {
      padding: 0;
    }

    .batch-verification__dialog-frame {
      height: calc(100dvh - 4rem);
      min-height: 0;
    }
  }

  /* ── Variant picker: tighter, mono-type chips ── */
  .variant-option__button-label {
    font-family: var(--font-mono--family, 'Courier New', monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-block: 0.5rem;
    padding-inline: 0.875rem;
    min-height: 2.25rem;
    flex: 0 0 auto;
    border-radius: 2px;
  }

  .variant-option__button-label:has(:checked):not(.variant-option__button-label--has-swatch, :has([data-option-available='false']))::before {
    border-color: rgb(var(--color-foreground-rgb));
  }

  .variant-option {
    gap: 0.375rem;
  }

  .variant-option__swatch-value {
    font-family: var(--font-mono--family, 'Courier New', monospace);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ---- Mobile footer composition --------------------------------------
     The footer is built from generic Horizon group blocks. On mobile, the
     default mobile-column behavior stacks brand, links, legal, and contact
     into one long list. Keep desktop unchanged, but make the mobile footer
     read as a compact utility area. */
  @media screen and (max-width: 749px) {
    .shopify-section-group-footer-group .section-content-wrapper {
      gap: 2.5rem;
      padding-block: 3.25rem 1.5rem;
    }

    .shopify-section-group-footer-group .section-content-wrapper > .group-block {
      width: 100%;
    }

    .shopify-section-group-footer-group .section-content-wrapper > .group-block > .group-block-content {
      align-items: stretch;
      gap: 2rem;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content {
      display: grid;
      height: auto;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
      gap: 2rem 1.5rem;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block {
      min-width: 0;
      width: 100%;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:first-child,
    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:nth-child(4) {
      grid-column: 1 / -1;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block
      > .group-block-content {
      height: auto;
      gap: 0.75rem;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:first-child
      .image-block {
      width: min(13.5rem, 64vw);
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:first-child
      .text-block {
      max-width: 34rem;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:not(:first-child)
      :is(.text-block, rte-formatter)
      p {
      margin: 0;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:not(:first-child)
      :is(.text-block, rte-formatter)
      p
      + p {
      margin-block-start: 0.62rem;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:nth-child(4) {
      padding-block-start: 1.35rem;
      border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:nth-child(4)
      > .group-block-content {
      display: grid;
      grid-template-columns: 6rem minmax(0, 1fr);
      align-items: start;
      gap: 0.25rem 1rem;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:first-child
      > .group-block-content
      > .group-block:nth-child(4)
      .text-block {
      min-width: 0;
      max-width: 100%;
    }

    .shopify-section-group-footer-group .section-content-wrapper a {
      overflow-wrap: anywhere;
      text-underline-offset: 0.18em;
    }

    .shopify-section-group-footer-group
      .section-content-wrapper
      > .group-block
      > .group-block-content
      > .group-block:nth-child(2) {
      padding-block-start: 1.25rem;
      border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    }
  }

  /* ---- Mobile tap targets (≥44px iOS guideline) ----------------------- */
  @media screen and (max-width: 749px) {
    .variant-option__button-label {
      min-height: 2.75rem;
      padding-block: 0.75rem;
      padding-inline: 1rem;
    }

    .variant-option {
      gap: 0.5rem;
    }

    product-card .quick-add__button .add-to-cart-text {
      padding: 1rem 1rem;
      min-height: 2.75rem;
    }

    .product-grid {
      row-gap: 2.25rem;
    }
  }
{% endstyle %}
