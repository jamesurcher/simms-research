{% doc %}
  Renders a static volume-discount info table on the PDP.

  Tier definitions come from theme settings (settings.volume_tier_N_qty /
  volume_tier_N_pct). The actual checkout discount is applied by a matching
  Shopify automatic Volume discount campaign — keep the numbers in sync.

  This is a non-interactive display only. Users control quantity via the
  standard quantity selector (+/- buttons).

  @param {variant} variant - The currently selected variant.
{% enddoc %}

{%- liquid
  assign enabled = settings.volume_pricing_enabled
  assign t1_qty = settings.volume_tier_1_qty | default: 0
  assign t1_pct = settings.volume_tier_1_pct | default: 0
  assign t2_qty = settings.volume_tier_2_qty | default: 0
  assign t2_pct = settings.volume_tier_2_pct | default: 0
  assign t3_qty = settings.volume_tier_3_qty | default: 0
  assign t3_pct = settings.volume_tier_3_pct | default: 0

  assign has_any_tier = false
  if t1_qty > 0 and t1_pct > 0
    assign has_any_tier = true
  endif
  if t2_qty > 0 and t2_pct > 0
    assign has_any_tier = true
  endif
  if t3_qty > 0 and t3_pct > 0
    assign has_any_tier = true
  endif
-%}

{%- if enabled and has_any_tier and variant -%}
  <div class="volume-discount-table">
    <span class="volume-discount-table__heading">Volume Discounts</span>
    <div class="volume-discount-table__tiers">
      {%- for i in (1..3) -%}
        {%- liquid
          case i
            when 1
              assign tier_qty = t1_qty
              assign tier_pct = t1_pct
            when 2
              assign tier_qty = t2_qty
              assign tier_pct = t2_pct
            when 3
              assign tier_qty = t3_qty
              assign tier_pct = t3_pct
          endcase

          if tier_qty <= 0 or tier_pct <= 0
            continue
          endif
        -%}

        <div class="volume-discount-table__tier">
          <span class="volume-discount-table__pct">{{ tier_pct }}% off</span>
          <span class="volume-discount-table__qty">{{ tier_qty }}+ vials</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .volume-discount-table {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: 100%;
    flex: 1 0 100%;
    grid-column: 1 / -1;
    margin-block: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgb(10 10 10 / 0.1);
    border-radius: 6px;
    background: rgb(10 10 10 / 0.02);
  }

  .volume-discount-table__heading {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(10 10 10 / 0.5);
  }

  .volume-discount-table__tiers {
    display: flex;
    gap: 0.6rem;
  }

  .volume-discount-table__tier {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 0.5rem;
    border: 1px solid rgb(10 10 10 / 0.08);
    border-radius: 4px;
    background: #fff;
  }

  .volume-discount-table__pct {
    font-size: 0.95rem;
    font-weight: 600;
    color: #0a0a0a;
    line-height: 1.2;
  }

  .volume-discount-table__qty {
    font-size: 0.75rem;
    color: rgb(10 10 10 / 0.5);
    line-height: 1.2;
  }
{% endstylesheet %}
