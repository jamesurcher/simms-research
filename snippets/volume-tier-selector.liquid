{% doc %}
  Renders volume-discount quantity shortcuts on the PDP.

  Tier definitions come from theme settings (settings.volume_tier_N_qty /
  volume_tier_N_pct). The actual checkout discount is applied by a matching
  Shopify automatic Volume discount campaign — keep the numbers in sync.

  Buttons set the standard quantity selector to the tier minimum so the
  native product form can submit the selected quantity.

  @param {variant} variant - The currently selected variant.
{% enddoc %}

{%- liquid
  assign enabled = settings.volume_pricing_enabled
  assign t1_qty = settings.volume_tier_1_qty | default: 0
  assign t1_pct = settings.volume_tier_1_pct | default: 0
  assign t2_qty = settings.volume_tier_2_qty | default: 0
  assign t2_pct = settings.volume_tier_2_pct | default: 0

  assign has_any_tier = false
  if t1_qty > 0 and t1_pct > 0
    assign has_any_tier = true
  endif
  if t2_qty > 0 and t2_pct > 0
    assign has_any_tier = true
  endif
-%}

{%- if enabled and has_any_tier and variant -%}
  <style>
    .volume-discount-table {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      width: 100%;
      flex: 1 0 100%;
      grid-column: 1 / -1;
      margin-block: 1rem;
      padding: 1rem 1.25rem;
      border: 1px solid rgb(10 10 10 / 0.1);
      border-radius: 6px;
      background: #fff;
    }
    .volume-discount-table__heading {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgb(10 10 10 / 0.5);
    }
    .volume-discount-table__tiers {
      display: flex;
      gap: 0.6rem;
      padding-block-start: 0.45rem;
    }
    .volume-discount-table__tier {
      appearance: none;
      -webkit-appearance: none;
      position: relative;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      padding: 0.75rem 0.5rem;
      border: 1px solid rgb(10 10 10 / 0.08);
      border-radius: 4px;
      background: #fff;
      color: #0a0a0a;
      font: inherit;
      cursor: pointer;
      transition: border-color 150ms ease, background-color 150ms ease, color 150ms ease, box-shadow 150ms ease;
    }
    .volume-discount-table__tier:hover,
    .volume-discount-table__tier:focus-visible,
    .volume-discount-table__tier[aria-pressed='true'] {
      border-color: #eee5d5;
      background: #fcfaf6;
      color: #0a0a0a;
      box-shadow: none;
    }
    .volume-discount-table__tier:focus-visible {
      outline: 2px solid #0a0a0a;
      outline-offset: 2px;
    }
    .volume-discount-table__badge {
      position: absolute;
      inset-block-start: -0.48rem;
      inset-inline: 50% auto;
      transform: translateX(-50%);
      padding: 0.14rem 0.34rem;
      border-radius: 999px;
      color: #fff;
      font-size: 0.48rem;
      font-weight: 700;
      letter-spacing: 0.035em;
      line-height: 1;
      pointer-events: none;
      text-transform: uppercase;
      white-space: nowrap;
    }
    .volume-discount-table__badge--popular {
      background: #4b9a85;
    }
    .volume-discount-table__badge--value {
      background: #e59a2f;
    }
    @media screen and (min-width: 750px) {
      .volume-discount-table__badge {
        font-size: 0.54rem;
      }
    }
    .volume-discount-table__pct {
      font-size: 0.95rem;
      font-weight: 600;
      color: currentColor;
      line-height: 1.2;
    }
    .volume-discount-table__qty {
      font-size: 0.75rem;
      color: currentColor;
      line-height: 1.2;
      opacity: 0.5;
    }
    .volume-discount-table__tier:is(:hover, :focus-visible, [aria-pressed='true']) .volume-discount-table__qty {
      opacity: 0.58;
    }
    .quick-add-modal__content .product-details .buy-buttons-block {
      margin-top: 0;
    }
  </style>
  <div class="volume-discount-table">
    <span class="volume-discount-table__heading">Bundle & Save</span>
    <div class="volume-discount-table__tiers">
      <button
        type="button"
        class="volume-discount-table__tier"
        on:click="/selectVolumeTier?quantity=1"
        data-volume-tier-quantity="1"
        aria-pressed="false"
        aria-label="Set quantity to 1 vial"
      >
        <span class="volume-discount-table__pct">1 vial</span>
      </button>

      {%- for i in (1..2) -%}
        {%- liquid
          case i
            when 1
              assign tier_qty = t1_qty
              assign tier_pct = t1_pct
            when 2
              assign tier_qty = t2_qty
              assign tier_pct = t2_pct
          endcase

          if tier_qty <= 0 or tier_pct <= 0
            continue
          endif
        -%}

        <button
          type="button"
          class="volume-discount-table__tier"
          on:click="/selectVolumeTier?quantity={{ tier_qty }}"
          data-volume-tier-quantity="{{ tier_qty }}"
          aria-pressed="false"
          aria-label="Set quantity to {{ tier_qty }} vials for {{ tier_pct }}% off"
        >
          {%- if i == 1 -%}
            <span class="volume-discount-table__badge volume-discount-table__badge--popular">Most popular</span>
          {%- elsif i == 2 -%}
            <span class="volume-discount-table__badge volume-discount-table__badge--value">Best value</span>
          {%- endif -%}
          <span class="volume-discount-table__pct">{{ tier_qty }}+ vials</span>
          <span class="volume-discount-table__qty">{{ tier_pct }}% off</span>
        </button>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}
