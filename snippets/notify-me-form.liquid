{% doc %}
  Renders a "Notify me when available" email capture form.
  Posts to the URL stored in settings.notify_endpoint as JSON.
  Used on the PDP when a variant is unavailable.

  @param {variant} variant - The currently selected variant (for variant_label).
  @param {product} product - The product (for title).
  @param {string} [block_id] - Used to scope element IDs when multiple instances render.
{% enddoc %}

{%- assign endpoint = settings.notify_endpoint | strip -%}
{%- assign form_id = 'notify-me-' | append: variant.id | append: '-' | append: block_id -%}
{%- assign variant_label = variant.title | default: '' -%}

<notify-me-form
  class="notify-me"
  data-endpoint="{{ endpoint | escape }}"
  data-product="{{ product.title | escape }}"
  data-product-handle="{{ product.handle | escape }}"
  data-variant-id="{{ variant.id }}"
  data-variant="{{ variant_label | escape }}"
>
  <p class="notify-me__heading">Notify me when available</p>
  <p class="notify-me__sub">
    Currently out of stock. Drop your email and we'll let you know when this batch is back in.
  </p>

  {%- comment -%}
    A <div> instead of <form> because this snippet renders inside the
    Shopify product <form>. Nested <form> elements are invalid HTML and
    the browser silently drops the inner one, which breaks JS.
  {%- endcomment -%}
  <div class="notify-me__form" id="{{ form_id }}" data-notify-form>
    <label class="notify-me__field">
      <span class="visually-hidden">Email address</span>
      <input
        type="email"
        name="notify_email"
        class="notify-me__input"
        placeholder="you@email.com"
        autocomplete="email"
        required
        data-notify-email
      >
    </label>

    {%- comment -%} Honeypot — bots will fill this; real users won't. {%- endcomment -%}
    <label class="notify-me__honeypot" aria-hidden="true">
      Website
      <input type="text" name="notify_website" tabindex="-1" autocomplete="off">
    </label>

    <button type="button" class="notify-me__submit" data-notify-submit>
      <span class="notify-me__submit-label">Notify me</span>
      <span class="notify-me__submit-loading" hidden>Sending&hellip;</span>
    </button>
  </div>

  <p class="notify-me__status" data-notify-status hidden></p>
</notify-me-form>

<script>
  (function () {
    if (window.__notifyMeInit) return;
    window.__notifyMeInit = true;

    // Sync buy-state visibility + notify-me data based on the current variant.
    //
    // Source of truth: the product form's <input name="id"> value. Shopify's
    // variant picker keeps this in sync with the user's selection. We then
    // look up that variant ID's availability via the matching variant-picker
    // radio's data-option-available attribute.
    //
    // Listening to radio change events alone is unreliable because:
    //   - Shopify may re-render parts of the section after a variant change
    //     (Section Rendering API), which can race with our event handlers.
    //   - The "checked" attribute and "data-current-checked" can disagree
    //     after JS-driven updates.
    function syncBuyState() {
      var idInput = document.querySelector(
        'product-form-component input[name="id"]'
      );
      if (!idInput) return;
      var variantId = idInput.value;
      if (!variantId) return;

      var radio = document.querySelector(
        'input[type="radio"][data-option-available][data-variant-id="' + variantId + '"]'
      );
      if (!radio) return;

      var available = radio.dataset.optionAvailable === 'true';
      var variantLabel = radio.value || '';

      document.querySelectorAll('[data-buy-state]').forEach(function (state) {
        state.setAttribute('data-variant-available', available ? 'true' : 'false');
        var notify = state.querySelector('notify-me-form');
        if (notify) {
          notify.dataset.variantId = variantId;
          notify.dataset.variant = variantLabel;
        }
      });
    }

    // Trigger sync from multiple signals — pick whichever fires first.
    // setTimeout(..., 0) defers one tick so Shopify's own handlers update
    // the form's id input before we read it.
    function deferredSync() { setTimeout(syncBuyState, 0); }

    document.addEventListener('change', function (e) {
      var radio = e.target.closest && e.target.closest('input[type="radio"][data-option-available]');
      if (radio) deferredSync();
    });
    document.addEventListener('variant:update', deferredSync);

    // Initial sync + a couple of follow-ups to catch any late-arriving
    // re-renders from the Section Rendering API.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncBuyState);
    } else {
      syncBuyState();
    }
    setTimeout(syncBuyState, 250);
    setTimeout(syncBuyState, 1000);

    if (!window.customElements || customElements.get('notify-me-form')) return;

    customElements.define('notify-me-form', class extends HTMLElement {
      connectedCallback() {
        this.form = this.querySelector('[data-notify-form]');
        this.email = this.querySelector('[data-notify-email]');
        this.submit = this.querySelector('[data-notify-submit]');
        this.label = this.querySelector('.notify-me__submit-label');
        this.loading = this.querySelector('.notify-me__submit-loading');
        this.status = this.querySelector('[data-notify-status]');
        this.endpoint = this.dataset.endpoint;

        if (!this.submit || !this.endpoint) return;

        this.submit.addEventListener('click', this.onSubmit.bind(this));
        // Pressing Enter in the email input should also submit.
        if (this.email) {
          this.email.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
              e.preventDefault();
              this.onSubmit(e);
            }
          });
        }
      }

      setBusy(busy) {
        this.submit.disabled = busy;
        this.label.hidden = busy;
        this.loading.hidden = !busy;
      }

      showStatus(msg, isError) {
        this.status.textContent = msg;
        this.status.hidden = false;
        this.status.classList.toggle('notify-me__status--error', !!isError);
      }

      async onSubmit(e) {
        e.preventDefault();
        if (this.submit.disabled) return;

        var email = (this.email.value || '').trim();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          this.showStatus('Please enter a valid email.', true);
          this.email.focus();
          return;
        }

        var payload = {
          email: email,
          product: this.dataset.product,
          product_handle: this.dataset.productHandle,
          variant: this.dataset.variant,
          variant_id: this.dataset.variantId,
          url: window.location.href,
          website: this.querySelector('input[name="notify_website"]').value
        };

        this.setBusy(true);
        this.status.hidden = true;

        // Apps Script web apps return opaque responses under `mode: 'no-cors'`
        // (and we use text/plain to avoid CORS preflight). We can't actually
        // read the response, so we race the network call against a 4-second
        // timeout — either way, we end the busy state and show the success
        // message. The Apps Script either appends the row or it doesn't; the
        // user's experience here is the same.
        var fetchPromise = fetch(this.endpoint, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'text/plain;charset=utf-8' },
          body: JSON.stringify(payload)
        }).catch(function () { /* swallow; treat as completion */ });

        var timeout = new Promise(function (resolve) { setTimeout(resolve, 4000); });

        await Promise.race([fetchPromise, timeout]);

        this.setBusy(false);
        if (this.form) this.form.hidden = true;
        this.showStatus('Got it. We’ll email you when this is back in stock.');
      }
    });
  })();
</script>

{% stylesheet %}
  /* Toggle in-stock UI vs notify form based on the wrapper's variant-available state. */
  [data-buy-state][data-variant-available="true"] [data-buy-state-notify],
  [data-buy-state][data-variant-available="false"] [data-buy-state-instock] {
    display: none;
  }

  /* Hide qty + add-to-cart row when the variant is unavailable.
     Uses :has() so we don't need the buttons-wrap to be a sibling of buy-state. */
  form:has([data-buy-state][data-variant-available="false"]) [data-buy-state-buttons],
  [data-buy-state][data-variant-available="false"] ~ [data-buy-state-buttons] {
    display: none !important;
  }

  .notify-me {
    display: block;
    width: 100%;
    padding: 1.25rem 1.25rem;
    background: #f5f5f5;
    border: 1px solid rgb(10 10 10 / 0.06);
    border-radius: 8px;
    margin-block: 1rem;
  }

  .notify-me__heading {
    margin: 0 0 0.35rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: #0a0a0a;
    letter-spacing: -0.005em;
  }

  .notify-me__sub {
    margin: 0 0 1rem;
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgb(10 10 10 / 0.65);
  }

  .notify-me__form {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.5rem;
  }

  .notify-me__field {
    grid-column: 1;
    display: block;
  }

  .notify-me__input {
    width: 100%;
    padding: 0.85rem 1rem;
    background: #ffffff;
    border: 1px solid rgb(10 10 10 / 0.12);
    border-radius: 6px;
    font: inherit;
    font-size: 0.92rem;
    color: #0a0a0a;
    appearance: none;
    -webkit-appearance: none;
    transition: border-color 150ms ease;
  }

  .notify-me__input:focus {
    outline: none;
    border-color: #0a0a0a;
  }

  .notify-me__input::placeholder {
    color: rgb(10 10 10 / 0.4);
  }

  .notify-me__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .notify-me__submit {
    grid-column: 2;
    appearance: none;
    border: 1px solid #0a0a0a;
    background: #0a0a0a;
    color: #ffffff;
    padding: 0.85rem 1.4rem;
    border-radius: 6px;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 150ms ease, color 150ms ease;
    white-space: nowrap;
  }

  .notify-me__submit:hover:not(:disabled) {
    background: #0a0a0a;
    color: #e4f5ff;
  }

  .notify-me__submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .notify-me__status {
    margin: 0.85rem 0 0;
    font-size: 0.82rem;
    line-height: 1.4;
    color: rgb(10 10 10 / 0.7);
  }

  .notify-me__status--error {
    color: #b00020;
  }

  @media (max-width: 480px) {
    .notify-me__form {
      grid-template-columns: 1fr;
    }
    .notify-me__submit {
      grid-column: 1;
    }
  }
{% endstylesheet %}
