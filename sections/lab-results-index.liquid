          "label": "Eyebrow (mono caps)",
          "default": "Analytical Methods"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "HPLC & Mass Spectrometry: Purity Verification"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lab results index",
      "blocks": [
        {
          "type": "callout",
          "settings": {
            "eyebrow": "Analytical Methods",
            "title": "HPLC & Mass Spectrometry: Purity Verification"
          }
        },
        {
          "type": "callout",
          "settings": {
            "eyebrow": "Documentation",
            "title": "Understanding Certificates of Analysis"
          }
        }
      ]
    }
  ]
}
