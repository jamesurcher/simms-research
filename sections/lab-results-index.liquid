{% comment %}
  Lab results index — full /pages/lab-results dashboard.

  Three states on one page:
    1. Index   — grid of product cards, each with inline batch summary
    2. Detail  — per-product full test table (toggled in place via URL hash)
    3. Dialog  — COA viewer modal (overlays either state)

  Reads existing PDP data model: product.metafields.coa.batches (list of
  coa_batch metaobjects) and the single-ref fallback product.metafields.coa.batch.
  Field shape per snippets/batch-verification.liquid: every field is .value-ed
  (e.g. batch.batch_id.value).
{% endcomment %}

{%- liquid
  assign total_batches = 0
  assign sum_purity = 0.0
  assign count_purity = 0
  assign entries_present = false

  # Pre-pass: compute totals across all products with COA data
  for product in collections.all.products
    assign batches = product.metafields.coa.batches.value
    assign single_batch = product.metafields.coa.batch.value

    if batches != blank
      for batch in batches
        assign total_batches = total_batches | plus: 1
        assign p_raw = batch.purity.value | default: batch.avg_purity.value
        if p_raw != blank
          assign p_num = p_raw | replace: '%', '' | strip | times: 1.0
          if p_num > 0
            assign sum_purity = sum_purity | plus: p_num
            assign count_purity = count_purity | plus: 1
          endif
        endif
      endfor
      assign entries_present = true
    elsif single_batch != blank
      assign total_batches = total_batches | plus: 1
      assign p_raw = single_batch.purity.value | default: single_batch.avg_purity.value
      if p_raw != blank
        assign p_num = p_raw | replace: '%', '' | strip | times: 1.0
        if p_num > 0
          assign sum_purity = sum_purity | plus: p_num
          assign count_purity = count_purity | plus: 1
        endif
      endif
      assign entries_present = true
    endif
  endfor

  if count_purity > 0
    assign avg_purity_value = sum_purity | divided_by: count_purity | round: 2
    assign avg_purity_display = avg_purity_value | append: '%'
  else
    assign avg_purity_display = '—'
  endif
-%}

<lab-results-page
  class="lab-results section section--page-width color-{{ section.settings.color_scheme }}"
  style="
    --lab-results-padding-block-start: {{ section.settings['padding-block-start'] }}px;
    --lab-results-padding-block-end: {{ section.settings['padding-block-end'] }}px;
  "
>
  <div class="lab-results__inner">

    {%- # 1. Hero -%}
    <header class="lab-results__hero">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lab-results__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="lab-results__heading">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}
      {%- if section.settings.subhead != blank -%}
        <p class="lab-results__subhead">{{ section.settings.subhead | escape }}</p>
      {%- endif -%}

      <dl class="lab-results__stats">
        <div class="lab-results__stat">
          <dt>Batches tested</dt>
          <dd>{{ total_batches }}</dd>
        </div>
        <div class="lab-results__stat">
          <dt>Avg purity</dt>
          <dd>{{ avg_purity_display }}</dd>
        </div>
        <div class="lab-results__stat">
          <dt>Endotoxin standard</dt>
          <dd>{{ section.settings.endotoxin_standard | escape }}</dd>
        </div>
        <div class="lab-results__stat">
          <dt>Lab partner</dt>
          <dd>{{ section.settings.lab_partner | escape }}</dd>
        </div>
      </dl>
    </header>

    {%- # 2. Search -%}
    <div class="lab-results__search" data-lab-search-wrap>
      <svg class="lab-results__search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.25"/>
        <path d="m11 11 3 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        class="lab-results__search-input"
        placeholder="Search by compound, batch ID, or CAS"
        aria-label="Search lab results"
        data-lab-search
        autocomplete="off"
        spellcheck="false"
      >
    </div>

    {%- if entries_present -%}

      {%- # 3a. Index grid -%}
      <ul class="lab-results__grid" data-lab-grid role="list">
        {%- for product in collections.all.products -%}
          {%- liquid
            assign batches = product.metafields.coa.batches.value
            assign single_batch = product.metafields.coa.batch.value
            assign entry_batches = batches
            if batches == blank and single_batch != blank
              assign entry_batches = single_batch
            endif
          -%}

          {%- if entry_batches != blank -%}
            {%- liquid
              # Build search haystack: title + cas + every batch_id
              assign cas_value = product.metafields.spec.cas.value | default: ''
              assign batch_ids_concat = ''
              if batches != blank
                for b in batches
                  assign bid = b.batch_id.value | default: ''
                  if bid != blank
                    assign batch_ids_concat = batch_ids_concat | append: ' ' | append: bid
                  endif
                endfor
              elsif single_batch != blank
                assign sbid = single_batch.batch_id.value | default: ''
                if sbid != blank
                  assign batch_ids_concat = batch_ids_concat | append: ' ' | append: sbid
                endif
              endif
              assign search_haystack = product.title | append: ' ' | append: cas_value | append: batch_ids_concat | downcase

              # Count batches for the card subtitle
              assign card_batch_count = 0
              if batches != blank
                assign card_batch_count = batches.size
              elsif single_batch != blank
                assign card_batch_count = 1
              endif
            -%}

            <li
              class="lab-card"
              data-lab-card
              data-product-handle="{{ product.handle }}"
              data-search="{{ search_haystack | escape }}"
            >
              <div class="lab-card__head">
                <h3 class="lab-card__title">{{ product.title | escape }}</h3>
                <p class="lab-card__count">
                  {{ card_batch_count }} batch{% if card_batch_count != 1 %}es{% endif %}
                </p>
              </div>

              <ul class="lab-card__rows" role="list">
                {%- if batches != blank -%}
                  {%- for batch in batches limit: 4 -%}
                    {%- liquid
                      assign b_id = batch.batch_id.value
                      assign b_purity = batch.purity.value | default: batch.avg_purity.value
                      assign b_tested = batch.tested_at.value
                      assign b_is_current = batch.is_current.value
                      assign b_file = batch.coa_file.value
                      assign b_url = b_file.url
                      if b_url == blank and b_file != blank
                        assign b_url = b_file | image_url: width: 2400
                      endif
                      if b_url == blank
                        assign b_url = batch.coa_url.value
                      endif
                    -%}
                    <li class="lab-card__row">
                      <span class="lab-card__row-id">
                        #{{ b_id | default: '—' | escape }}
                        {%- if b_is_current == true -%}
                          <span class="lab-card__pill">Latest</span>
                        {%- endif -%}
                      </span>
                      <span class="lab-card__row-meta">
                        {%- if b_purity != blank -%}
                          <span class="lab-card__row-purity">{{ b_purity | escape }}</span>
                        {%- endif -%}
                        {%- if b_tested != blank -%}
                          <span class="lab-card__row-date">{{ b_tested | date: '%b %-d, %Y' }}</span>
                        {%- endif -%}
                      </span>
                      {%- if b_url != blank -%}
                        <button
                          type="button"
                          class="lab-card__row-coa"
                          data-lab-coa
                          data-coa-url="{{ b_url | escape }}"
                          data-coa-title="{{ product.title | escape }} — #{{ b_id | escape }}"
                        >View COA</button>
                      {%- else -%}
                        <span class="lab-card__row-coa lab-card__row-coa--missing" aria-disabled="true">—</span>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                {%- elsif single_batch != blank -%}
                  {%- liquid
                    assign b_id = single_batch.batch_id.value
                    assign b_purity = single_batch.purity.value | default: single_batch.avg_purity.value
                    assign b_tested = single_batch.tested_at.value
                    assign b_is_current = single_batch.is_current.value
                    assign b_file = single_batch.coa_file.value
                    assign b_url = b_file.url
                    if b_url == blank and b_file != blank
                      assign b_url = b_file | image_url: width: 2400
                    endif
                    if b_url == blank
                      assign b_url = single_batch.coa_url.value
                    endif
                  -%}
                  <li class="lab-card__row">
                    <span class="lab-card__row-id">
                      #{{ b_id | default: '—' | escape }}
                      {%- if b_is_current == true -%}
                        <span class="lab-card__pill">Latest</span>
                      {%- endif -%}
                    </span>
                    <span class="lab-card__row-meta">
                      {%- if b_purity != blank -%}
                        <span class="lab-card__row-purity">{{ b_purity | escape }}</span>
                      {%- endif -%}
                      {%- if b_tested != blank -%}
                        <span class="lab-card__row-date">{{ b_tested | date: '%b %-d, %Y' }}</span>
                      {%- endif -%}
                    </span>
                    {%- if b_url != blank -%}
                      <button
                        type="button"
                        class="lab-card__row-coa"
                        data-lab-coa
                        data-coa-url="{{ b_url | escape }}"
                        data-coa-title="{{ product.title | escape }} — #{{ b_id | escape }}"
                      >View COA</button>
                    {%- endif -%}
                  </li>
                {%- endif -%}
              </ul>

              <a
                href="#tests/{{ product.handle }}"
                class="lab-card__details"
                data-lab-detail-link
                data-product-handle="{{ product.handle }}"
              >View full test details <span aria-hidden="true">→</span></a>
            </li>
          {%- endif -%}
        {%- endfor -%}

        <li class="lab-results__no-results" data-lab-no-results hidden>
          <p>No matches. Try a different compound, batch ID, or CAS.</p>
        </li>
      </ul>

      {%- # 3b. Per-product detail tables (one per product, all hidden by default) -%}
      {%- for product in collections.all.products -%}
        {%- liquid
          assign batches = product.metafields.coa.batches.value
          assign single_batch = product.metafields.coa.batch.value
          assign detail_batches = batches
          if batches == blank and single_batch != blank
            assign detail_batches = single_batch
          endif
        -%}

        {%- if detail_batches != blank -%}
          <section
            class="lab-results__detail"
            data-lab-detail
            data-product-handle="{{ product.handle }}"
            aria-label="{{ product.title | escape }} test results"
            hidden
          >
            <div class="lab-results__detail-bar">
              <button type="button" class="lab-results__back" data-lab-back>
                <span aria-hidden="true">←</span> Back to all tests
              </button>
              <button type="button" class="lab-results__close" data-lab-back aria-label="Close detail view">Close</button>
            </div>

            <h2 class="lab-results__detail-title">
              {{ product.title | escape }}
              <span class="lab-results__detail-title-divider" aria-hidden="true">—</span>
              <span class="lab-results__detail-title-suffix">Test Results</span>
            </h2>

            <div class="lab-results__table-wrap">
              <table class="lab-results__table">
                <thead>
                  <tr>
                    <th scope="col">Batch</th>
                    <th scope="col">Purity</th>
                    <th scope="col">Vials Tested</th>
                    <th scope="col">Net Content</th>
                    <th scope="col">Endotoxins</th>
                    <th scope="col">Heavy Metals</th>
                    <th scope="col">Sterility</th>
                    <th scope="col">Test Date</th>
                    <th scope="col"><span class="visually-hidden">COA</span></th>
                  </tr>
                </thead>
                <tbody>
                  {%- if batches != blank -%}
                    {%- for batch in batches -%}
                      {%- render 'lab-results-row', batch: batch, product: product -%}
                    {%- endfor -%}
                  {%- elsif single_batch != blank -%}
                    {%- render 'lab-results-row', batch: single_batch, product: product -%}
                  {%- endif -%}
                </tbody>
              </table>
            </div>
          </section>
        {%- endif -%}
      {%- endfor -%}

    {%- else -%}
      {%- # Empty state — no products have batch data yet -%}
      <div class="lab-results__empty">
        <p>Lab results publishing soon. Every batch we ship will appear here.</p>
      </div>
    {%- endif -%}

    {%- # 4. Educational callouts -%}
    {%- if section.blocks.size > 0 -%}
      <div class="lab-results__callouts">
        {%- for block in section.blocks -%}
          {%- if block.type == 'callout' -%}
            {%- assign callout_url = block.settings.url -%}
            {%- if callout_url == blank -%}
              <div class="lab-results__callout lab-results__callout--static" {{ block.shopify_attributes }}>
                {%- if block.settings.eyebrow != blank -%}
                  <p class="lab-results__callout-eyebrow">{{ block.settings.eyebrow | escape }}</p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <p class="lab-results__callout-title">{{ block.settings.title | escape }}</p>
                {%- endif -%}
              </div>
            {%- else -%}
              <a class="lab-results__callout" href="{{ callout_url }}" {{ block.shopify_attributes }}>
                {%- if block.settings.eyebrow != blank -%}
                  <p class="lab-results__callout-eyebrow">{{ block.settings.eyebrow | escape }}</p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <p class="lab-results__callout-title">
                    {{ block.settings.title | escape }}
                    <span class="lab-results__callout-arrow" aria-hidden="true">→</span>
                  </p>
                {%- endif -%}
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- # 5. Disclaimer -%}
    {%- if section.settings.disclaimer != blank -%}
      <p class="lab-results__disclaimer">* {{ section.settings.disclaimer | escape }}</p>
    {%- endif -%}

    {%- # 6. COA dialog (single element, src + title set by JS) -%}
    <dialog class="lab-results__dialog" data-lab-dialog aria-label="Certificate of analysis">
      <div class="lab-results__dialog-shell">
        <div class="lab-results__dialog-bar">
          <p class="lab-results__dialog-title" data-lab-dialog-title>Certificate of Analysis</p>
          <button type="button" class="lab-results__dialog-close" data-lab-dialog-close aria-label="Close">×</button>
        </div>
        <div class="lab-results__dialog-body">
          <iframe data-lab-dialog-frame src="about:blank" title="Certificate of Analysis"></iframe>
        </div>
      </div>
    </dialog>

  </div>
</lab-results-page>

<script>
  if (!customElements.get('lab-results-page')) {
    customElements.define(
      'lab-results-page',
      class LabResultsPage extends HTMLElement {
        connectedCallback() {
          this.grid       = this.querySelector('[data-lab-grid]');
          this.details    = this.querySelectorAll('[data-lab-detail]');
          this.searchInput = this.querySelector('[data-lab-search]');
          this.noResults  = this.querySelector('[data-lab-no-results]');
          this.dialog     = this.querySelector('[data-lab-dialog]');
          this.dialogFrame = this.querySelector('[data-lab-dialog-frame]');
          this.dialogTitle = this.querySelector('[data-lab-dialog-title]');

          this.handleHashChange = () => this.applyHash();
          this.handleClick      = (e) => this.onClick(e);
          this.handleSearch     = () => this.scheduleSearch();
          this.handleKeydown    = (e) => { if (e.key === 'Escape' && this.dialog?.open) this.closeDialog(); };

          window.addEventListener('hashchange', this.handleHashChange);
          this.addEventListener('click', this.handleClick);
          this.searchInput?.addEventListener('input', this.handleSearch);
          this.dialog?.addEventListener('click', (e) => {
            if (e.target === this.dialog) this.closeDialog();
          });
          document.addEventListener('keydown', this.handleKeydown);

          this.applyHash();
        }

        disconnectedCallback() {
          window.removeEventListener('hashchange', this.handleHashChange);
          this.removeEventListener('click', this.handleClick);
          this.searchInput?.removeEventListener('input', this.handleSearch);
          document.removeEventListener('keydown', this.handleKeydown);
        }

        onClick(event) {
          const coaTrigger = event.target.closest('[data-lab-coa]');
          if (coaTrigger) {
            event.preventDefault();
            this.openDialog(coaTrigger.dataset.coaUrl, coaTrigger.dataset.coaTitle);
            return;
          }
          if (event.target.closest('[data-lab-dialog-close]')) {
            event.preventDefault();
            this.closeDialog();
            return;
          }
          if (event.target.closest('[data-lab-back]')) {
            event.preventDefault();
            this.clearHash();
            return;
          }
        }

        applyHash() {
          const hash = (window.location.hash || '').replace(/^#/, '');
          const match = hash.match(/^tests\/(.+)$/);
          const handle = match ? match[1] : null;

          let activeDetail = null;
          this.details.forEach((el) => {
            const isMatch = handle && el.dataset.productHandle === handle;
            el.hidden = !isMatch;
            if (isMatch) activeDetail = el;
          });

          if (activeDetail) {
            this.grid.hidden = true;
            if (this.searchInput) this.searchInput.value = '';
            if (this.noResults) this.noResults.hidden = true;
            // Scroll into view so user lands on the detail title, not the page top
            requestAnimationFrame(() => {
              activeDetail.scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
          } else {
            this.grid.hidden = false;
          }
        }

        clearHash() {
          if (window.location.hash) {
            // Use pushState so back-button restores the previous detail view
            history.pushState(null, '', window.location.pathname + window.location.search);
            this.applyHash();
          }
        }

        scheduleSearch() {
          if (this.searchTimer) cancelAnimationFrame(this.searchTimer);
          this.searchTimer = requestAnimationFrame(() => this.applySearch());
        }

        applySearch() {
          const raw = (this.searchInput?.value || '').trim().toLowerCase();
          const terms = raw.split(/\s+/).filter(Boolean);
          const cards = this.grid.querySelectorAll('[data-lab-card]');
          let visible = 0;
          cards.forEach((card) => {
            const haystack = (card.dataset.search || '').toLowerCase();
            const matches = terms.length === 0 || terms.every((t) => haystack.includes(t));
            card.hidden = !matches;
            if (matches) visible++;
          });
          if (this.noResults) {
            this.noResults.hidden = (visible > 0 || terms.length === 0);
          }
        }

        openDialog(url, title) {
          if (!this.dialog || !url) return;
          if (this.dialogFrame) this.dialogFrame.src = url;
          if (this.dialogTitle && title) this.dialogTitle.textContent = title;
          if (typeof this.dialog.showModal === 'function') {
            this.dialog.showModal();
            document.documentElement.setAttribute('scroll-lock', '');
          } else {
            window.open(url, '_blank', 'noopener');
          }
        }

        closeDialog() {
          if (!this.dialog) return;
          if (typeof this.dialog.close === 'function') this.dialog.close();
          document.documentElement.removeAttribute('scroll-lock');
          if (this.dialogFrame) this.dialogFrame.src = 'about:blank';
        }
      }
    );
  }
</script>

{% stylesheet %}
  .lab-results {
    background: var(--color-background);
    color: var(--color-foreground);
    padding-block-start: var(--lab-results-padding-block-start, 48px);
    padding-block-end: var(--lab-results-padding-block-end, 120px);
  }

  .lab-results__inner {
    /* Match the footer's nested 85% rail (group-block at width:85% inside section--page-width) */
    width: 85%;
    margin-inline: auto;
  }

  @media (max-width: 749px) {
    .lab-results__inner {
      width: 100%;
    }
  }

  .lab-results .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---------- Hero ---------- */

  .lab-results__hero {
    margin-block-end: clamp(2.5rem, 5vw, 4rem);
  }

  .lab-results__eyebrow {
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin: 0 0 1.25rem 0;
  }

  .lab-results__heading {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: clamp(2rem, 3.6vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 1rem 0;
    max-width: 24ch;
  }

  .lab-results__subhead {
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    max-width: 56ch;
    margin: 0 0 clamp(2.5rem, 4vw, 3.5rem) 0;
  }

  .lab-results__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2.5rem);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: 16px;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    padding: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0;
  }

  .lab-results__stat {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    justify-content: center;
  }

  .lab-results__stat dt {
    order: 2;
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    margin: 0;
  }

  .lab-results__stat dd {
    order: 1;
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0;
  }

  /* ---------- Search ---------- */

  .lab-results__search {
    position: relative;
    max-width: 720px;
    margin-block-end: clamp(1.75rem, 3vw, 2.5rem);
  }

  .lab-results__search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgb(var(--color-foreground-rgb) / 0.45);
    pointer-events: none;
  }

  .lab-results__search-input {
    width: 100%;
    appearance: none;
    background: transparent;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.18);
    border-radius: 999px;
    padding: 0.875rem 1rem 0.875rem 2.625rem;
    font-family: var(--font-mono--family);
    font-size: 0.875rem;
    color: var(--color-foreground);
    transition: border-color 120ms ease, box-shadow 120ms ease;
  }

  .lab-results__search-input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.42);
  }

  .lab-results__search-input:focus {
    outline: none;
    border-color: var(--color-foreground);
    box-shadow: 0 0 0 3px #e4f5ff;
  }

  /* Hide the native search clear button for visual consistency */
  .lab-results__search-input::-webkit-search-cancel-button { -webkit-appearance: none; }

  /* ---------- Index grid ---------- */

  .lab-results__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .lab-results__grid[hidden] { display: none; }

  .lab-results__no-results {
    grid-column: 1 / -1;
    padding: 3rem 1rem;
    text-align: center;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font-family: var(--font-mono--family);
    font-size: 0.8125rem;
  }

  .lab-results__no-results p { margin: 0; }

  .lab-card {
    list-style: none;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    border-radius: 16px;
    padding: 1.5rem 1.5rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 160ms ease, background 160ms ease;
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .lab-card:hover {
    border-color: rgb(var(--color-foreground-rgb) / 0.32);
  }

  .lab-card__head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .lab-card__title {
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.2;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .lab-card__count {
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    margin: 0;
  }

  .lab-card__rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
  }

  .lab-card__row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "id   coa"
      "meta meta";
    align-items: center;
    column-gap: 1rem;
    row-gap: 0.4rem;
    padding-block: 0.875rem;
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    font-family: var(--font-mono--family);
    font-size: 0.8125rem;
    line-height: 1.3;
  }

  .lab-card__row:last-child {
    border-block-end: none;
  }

  .lab-card__row-id {
    grid-area: id;
    color: rgb(var(--color-foreground-rgb) / 0.74);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .lab-card__pill {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #009b57;
    background: rgb(0 155 87 / 0.1);
    border: 1px solid rgb(0 155 87 / 0.32);
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    line-height: 1.4;
  }

  .lab-card__row-meta {
    grid-area: meta;
    display: inline-flex;
    align-items: baseline;
    gap: 0.625rem;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .lab-card__row-purity {
    color: #009b57;
    font-weight: 500;
  }

  .lab-card__row-date {
    color: rgb(var(--color-foreground-rgb) / 0.5);
    white-space: nowrap;
  }

  .lab-card__row-coa {
    grid-area: coa;
    appearance: none;
    background: transparent;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.22);
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 120ms ease, color 120ms ease, background 120ms ease;
  }

  .lab-card__row-coa:hover,
  .lab-card__row-coa:focus-visible {
    border-color: var(--color-foreground);
    background: #e4f5ff;
    outline: none;
  }

  .lab-card__row-coa--missing {
    border: none;
    color: rgb(var(--color-foreground-rgb) / 0.3);
    cursor: default;
    padding: 0.35rem 0;
  }

  .lab-card__details {
    margin-block-start: auto;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    color: rgb(var(--color-foreground-rgb) / 0.66);
    text-decoration: none;
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    padding-block-start: 0.875rem;
    width: 100%;
    transition: color 120ms ease;
  }

  .lab-card__details:hover,
  .lab-card__details:focus-visible {
    color: var(--color-foreground);
    outline: none;
  }

  .lab-card__details:hover span {
    transform: translateX(3px);
  }

  .lab-card__details span {
    display: inline-block;
    transition: transform 160ms ease;
  }

  /* ---------- Empty state ---------- */

  .lab-results__empty {
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.18);
    border-radius: 16px;
    padding: clamp(2.5rem, 6vw, 4rem) 1rem;
    text-align: center;
    font-family: var(--font-mono--family);
    font-size: 0.875rem;
    color: rgb(var(--color-foreground-rgb) / 0.6);
  }

  .lab-results__empty p { margin: 0; }

  /* ---------- Detail view ---------- */

  .lab-results__detail[hidden] { display: none; }

  .lab-results__detail {
    display: block;
    margin-block: 1rem 1rem;
  }

  .lab-results__detail-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-block-end: 1.5rem;
    padding-block-end: 1rem;
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
  }

  .lab-results__back,
  .lab-results__close {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0;
    font-family: var(--font-mono--family);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgb(var(--color-foreground-rgb) / 0.66);
    cursor: pointer;
    transition: color 120ms ease;
  }

  .lab-results__back:hover,
  .lab-results__back:focus-visible,
  .lab-results__close:hover,
  .lab-results__close:focus-visible {
    color: var(--color-foreground);
    outline: none;
  }

  .lab-results__detail-title {
    font-family: var(--font-heading--family);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem 0;
  }

  .lab-results__detail-title-divider {
    color: rgb(var(--color-foreground-rgb) / 0.3);
    margin-inline: 0.5rem;
  }

  .lab-results__detail-title-suffix {
    color: rgb(var(--color-foreground-rgb) / 0.5);
  }

  .lab-results__table-wrap {
    overflow-x: auto;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 16px;
  }

  .lab-results__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono--family);
    font-size: 0.8125rem;
    min-width: 880px;
  }

  .lab-results__table th,
  .lab-results__table td {
    padding: 0.875rem 1rem;
    text-align: left;
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    vertical-align: middle;
    white-space: nowrap;
  }

  .lab-results__table tbody tr:last-child td {
    border-block-end: none;
  }

  .lab-results__table th {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    background: rgb(var(--color-foreground-rgb) / 0.025);
  }

  .lab-results__table td {
    color: rgb(var(--color-foreground-rgb) / 0.78);
  }

  .lab-results__td--purity { color: #009b57; font-weight: 500; }
  .lab-results__td--pass   { color: #009b57; }

  .lab-results__delta {
    display: inline-block;
    margin-inline-start: 0.4rem;
    color: #009b57;
    font-weight: 500;
  }

  .lab-results__pill {
    display: inline-block;
    margin-inline-start: 0.5rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #009b57;
    background: rgb(0 155 87 / 0.1);
    border: 1px solid rgb(0 155 87 / 0.32);
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    line-height: 1.4;
    vertical-align: 1px;
  }

  .lab-results__td-coa {
    appearance: none;
    background: transparent;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.22);
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground);
    cursor: pointer;
    transition: border-color 120ms ease, background 120ms ease;
  }

  .lab-results__td-coa:hover,
  .lab-results__td-coa:focus-visible {
    border-color: var(--color-foreground);
    background: #e4f5ff;
    outline: none;
  }

  /* ---------- Educational callouts ---------- */

  .lab-results__callouts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin-block-start: clamp(2.5rem, 5vw, 4rem);
  }

  .lab-results__callout {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 16px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-foreground);
    transition: border-color 160ms ease, transform 200ms ease;
  }

  .lab-results__callout:not(.lab-results__callout--static):hover,
  .lab-results__callout:not(.lab-results__callout--static):focus-visible {
    border-color: var(--color-foreground);
    outline: none;
  }

  .lab-results__callout-eyebrow {
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    margin: 0;
  }

  .lab-results__callout-title {
    font-family: var(--font-body--family);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    display: inline-flex;
    gap: 0.6rem;
    align-items: baseline;
  }

  .lab-results__callout-arrow {
    color: rgb(var(--color-foreground-rgb) / 0.45);
    transition: transform 160ms ease, color 160ms ease;
  }

  .lab-results__callout:hover .lab-results__callout-arrow {
    transform: translateX(3px);
    color: var(--color-foreground);
  }

  /* ---------- Disclaimer ---------- */

  .lab-results__disclaimer {
    margin-block-start: clamp(2rem, 4vw, 3rem);
    padding-block-start: 1.5rem;
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.4);
    text-align: center;
  }

  /* ---------- Dialog ---------- */

  .lab-results__dialog {
    width: min(92vw, 64rem);
    max-width: none;
    max-height: 90dvh;
    border: none;
    border-radius: 18px;
    padding: 0;
    background: var(--color-background);
    color: var(--color-foreground);
    box-shadow: 0 30px 80px -20px rgb(0 0 0 / 0.35);
    overflow: hidden;
  }

  .lab-results__dialog::backdrop {
    background: rgb(0 0 0 / 0.62);
    backdrop-filter: blur(6px);
  }

  .lab-results__dialog-shell {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-height: 90dvh;
  }

  .lab-results__dialog-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .lab-results__dialog-title {
    font-family: var(--font-mono--family);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.66);
    margin: 0;
  }

  .lab-results__dialog-close {
    appearance: none;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    font-size: 1.5rem;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    border-radius: 8px;
    transition: background 120ms ease;
  }

  .lab-results__dialog-close:hover,
  .lab-results__dialog-close:focus-visible {
    background: rgb(var(--color-foreground-rgb) / 0.08);
    outline: none;
  }

  .lab-results__dialog-body {
    flex: 1;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    overflow: auto;
  }

  .lab-results__dialog-body iframe {
    display: block;
    width: 100%;
    height: 75dvh;
    border: none;
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  /* ---------- Responsive ---------- */

  @media (max-width: 989px) {
    .lab-results__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .lab-results__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.5rem;
    }
    .lab-results__grid {
      grid-template-columns: 1fr;
    }
    .lab-results__detail-bar {
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .lab-results__dialog {
      width: 100vw;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
    }
    .lab-results__dialog-body iframe {
      height: calc(100dvh - 56px);
    }
  }
{% endstylesheet %}

