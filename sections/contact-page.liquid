{% liquid
  assign form_id = 'ContactPageForm-' | append: section.id
%}

<section class="contact-page color-{{ section.settings.color_scheme }}">
  <div class="contact-page__shell">
    <div class="contact-page__header">
      <p class="contact-page__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="contact-page__title">{{ section.settings.heading }}</h1>
      <div class="contact-page__intro">
        {{ section.settings.intro }}
      </div>
    </div>

    <div class="contact-page__grid">
      <aside class="contact-page__details" aria-label="Contact details">
        <div class="contact-page__card contact-page__card--primary">
          <p class="contact-page__label">Email</p>
          <a href="mailto:{{ section.settings.email | escape }}" class="contact-page__value">
            {{ section.settings.email }}
          </a>
          <p class="contact-page__meta">{{ section.settings.email_note }}</p>
        </div>

        <div class="contact-page__card">
          <p class="contact-page__label">Order Support</p>
          <p class="contact-page__value">{{ section.settings.order_support_heading }}</p>
          <p class="contact-page__meta">{{ section.settings.order_support_note }}</p>
        </div>

        <div class="contact-page__card">
          <p class="contact-page__label">Research / Product Questions</p>
          <p class="contact-page__value">{{ section.settings.research_heading }}</p>
          <p class="contact-page__meta">{{ section.settings.research_note }}</p>
        </div>

        <div class="contact-page__card">
          <p class="contact-page__label">Support Hours</p>
          <p class="contact-page__value">{{ section.settings.support_hours_days }}</p>
          <p class="contact-page__meta">{{ section.settings.support_hours_time }}</p>
        </div>
      </aside>

      <div class="contact-page__form-panel">
        <div class="contact-page__form-header">
          <p class="contact-page__label">Send a Message</p>
          <p>{{ section.settings.form_note }}</p>
        </div>

        {%- form 'contact', id: form_id, class: 'contact-page__form' -%}
          <input name="contact[id]" type="hidden" value="{{ form_id }}">

          {%- if form.errors and form.id == form_id -%}
            <div class="contact-page__message contact-page__message--error" tabindex="-1" autofocus>
              {{- 'icon-error.svg' | inline_asset_content -}}
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </div>
          {%- endif -%}

          {%- if form.posted_successfully? and form.id == form_id -%}
            <div class="contact-page__message contact-page__message--success" tabindex="-1" autofocus>
              {{- 'icon-checkmark.svg' | inline_asset_content -}}
              {{- 'blocks.contact_form.post_success' | t -}}
            </div>
          {%- endif -%}

          <div class="contact-page__row">
            <div class="contact-page__field">
              <label for="{{ form_id }}-name">Name</label>
              <input
                type="text"
                id="{{ form_id }}-name"
                name="contact[name]"
                autocomplete="name"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="Your name"
              >
            </div>

            <div class="contact-page__field">
              <label for="{{ form_id }}-email">Email <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="{{ form_id }}-email"
                name="contact[email]"
                autocomplete="email"
                spellcheck="false"
                autocapitalize="off"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                aria-required="true"
                {% if form.errors contains 'email' and form.id == form_id %}
                  aria-invalid="true"
                {% endif %}
                placeholder="you@example.com"
                required
              >
            </div>
          </div>

          <div class="contact-page__row">
            <div class="contact-page__field">
              <label for="{{ form_id }}-phone">Phone</label>
              <input
                type="tel"
                id="{{ form_id }}-phone"
                name="contact[phone]"
                autocomplete="tel"
                pattern="[0-9\-]*"
                value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                placeholder="Optional"
              >
            </div>

            <div class="contact-page__field">
              <label for="{{ form_id }}-topic">Subject</label>
              <select id="{{ form_id }}-topic" name="contact[subject]">
                <option value="Order Support">Order Support</option>
                <option value="Research / Product Question">Research / Product Question</option>
                <option value="Wholesale / Partnership">Wholesale / Partnership</option>
                <option value="General Inquiry">General Inquiry</option>
              </select>
            </div>
          </div>

          <div class="contact-page__field">
            <label for="{{ form_id }}-body">Message</label>
            <textarea
              rows="9"
              id="{{ form_id }}-body"
              name="contact[body]"
              placeholder="How can we help?"
            >{{- form.body -}}</textarea>
          </div>

          <button type="submit" class="button contact-page__submit">
            Send Message
          </button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .contact-page {
    padding-block: clamp(3rem, 7vw, 6.5rem);
    background:
      radial-gradient(circle at 15% 10%, rgb(var(--color-foreground-rgb) / 0.035), transparent 28rem),
      rgb(var(--color-background-rgb));
  }

  .contact-page__shell {
    display: grid;
    gap: clamp(2rem, 4vw, 3.8rem);
    width: min(100% - 2rem, 85rem);
    margin-inline: auto;
  }

  @media screen and (min-width: 750px) {
    .contact-page__shell {
      width: min(72.25vw, 85rem);
    }
  }

  .contact-page__header {
    max-width: 50rem;
  }

  .contact-page__eyebrow,
  .contact-page__label,
  .contact-page__field label {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.48);
    font-family: var(--font-mono--family);
    font-size: 0.75rem;
    font-weight: var(--font-mono--weight);
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .contact-page__title {
    max-width: 40rem;
    margin: 0.85rem 0 0;
    font-size: clamp(3rem, 4.2vw, 4rem);
    letter-spacing: -0.055em;
    line-height: 0.96;
  }

  .contact-page__intro {
    max-width: 48rem;
    margin-block-start: 1.05rem;
    color: rgb(var(--color-foreground-rgb) / 0.62);
    font-size: clamp(1rem, 1.45vw, 1.18rem);
    line-height: 1.45;
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.75rem, 3vw, 2.4rem);
    align-items: start;
  }

  .contact-page__details {
    display: grid;
    gap: 1rem;
  }

  .contact-page__card,
  .contact-page__form-panel {
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 18px;
    background:
      linear-gradient(rgb(var(--color-foreground-rgb) / 0.028), rgb(var(--color-foreground-rgb) / 0.028)),
      rgb(var(--color-background-rgb));
  }

  .contact-page__card {
    padding: 1.15rem 1.25rem;
  }

  .contact-page__card--primary {
    border-color: rgb(var(--color-foreground-rgb) / 0.18);
  }

  .contact-page__value {
    display: block;
    margin-block-start: 0.45rem;
    color: rgb(var(--color-foreground-rgb) / 0.86);
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.25;
    text-decoration: none;
  }

  .contact-page__value:hover {
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .contact-page__meta {
    margin: 0.35rem 0 0;
    color: rgb(var(--color-foreground-rgb) / 0.54);
    font-size: 0.9375rem;
    line-height: 1.45;
  }

  .contact-page__form-panel {
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .contact-page__form-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-block-end: 1.25rem;
  }

  .contact-page__form-header p:last-child {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    font-size: 0.875rem;
  }

  .contact-page__form {
    display: grid;
    gap: 1rem;
  }

  .contact-page__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .contact-page__field {
    display: grid;
    gap: 0.45rem;
  }

  .contact-page__field :is(input, select, textarea) {
    width: 100%;
    min-height: 3.3rem;
    padding: 0.85rem 1rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
    border-radius: 14px;
    background: rgb(var(--color-background-rgb) / 0.62);
    color: var(--color-foreground);
    font: inherit;
  }

  .contact-page__field textarea {
    min-height: 16rem;
    resize: vertical;
  }

  .contact-page__field :is(input, select, textarea)::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.42);
  }

  .contact-page__field :is(input, select, textarea):focus {
    border-color: rgb(var(--color-foreground-rgb) / 0.46);
    outline: 2px solid rgb(var(--color-foreground-rgb) / 0.1);
    outline-offset: 2px;
  }

  .contact-page__submit {
    width: 100%;
    min-height: 3.35rem;
    margin-block-start: 0.2rem;
    border-radius: 999px;
  }

  .contact-page__message {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1rem;
    border-radius: 14px;
    font-size: 0.9375rem;
  }

  .contact-page__message--error {
    background: rgb(190 18 60 / 0.08);
    color: rgb(136 19 55);
  }

  .contact-page__message--success {
    background: rgb(0 155 87 / 0.08);
    color: #007a46;
  }

  .contact-page__message svg {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  @media screen and (max-width: 989px) {
    .contact-page__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    .contact-page {
      padding-block: 2.5rem 4rem;
    }

    .contact-page__title {
      font-size: clamp(2.8rem, 16vw, 4rem);
    }

    .contact-page__row,
    .contact-page__form-header {
      grid-template-columns: 1fr;
      display: grid;
    }

    .contact-page__form-header {
      gap: 0.35rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Simms"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Have a question about an order, product handling, or a partnership request? Send a message and we will route it to the right place.</p>"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "support@simmsresearch.com"
    },
    {
      "type": "text",
      "id": "email_note",
      "label": "Email note",
      "default": "Most messages receive a response within one business day."
    },
    {
      "type": "text",
      "id": "order_support_heading",
      "label": "Order support heading",
      "default": "Existing orders"
    },
    {
      "type": "text",
      "id": "order_support_note",
      "label": "Order support note",
      "default": "Include your order number for status, shipping, or account questions."
    },
    {
      "type": "text",
      "id": "research_heading",
      "label": "Research heading",
      "default": "Product questions"
    },
    {
      "type": "text",
      "id": "research_note",
      "label": "Research note",
      "default": "For COA, storage, handling, or product-detail questions."
    },
    {
      "type": "text",
      "id": "support_hours_days",
      "label": "Support hours days",
      "default": "Monday - Friday"
    },
    {
      "type": "text",
      "id": "support_hours_time",
      "label": "Support hours time",
      "default": "9 AM - 5 PM EST"
    },
    {
      "type": "text",
      "id": "form_note",
      "label": "Form note",
      "default": "Required fields are marked."
    }
  ],
  "presets": [
    {
      "name": "Contact page"
    }
  ]
}
{% endschema %}
