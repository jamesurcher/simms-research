{%- comment -%}
  Newsletter research — email signup.

  Inspired by Rue Peptides' "First to know. First to research." section.
  Two-column split: editorial pitch on the left (eyebrow + heading + body),
  form on the right (pill email + filled submit). Uses Shopify's native
  customer-creation form for the email capture and inherits the same
  brand-voice rules (Inter heading, mono caps eyebrow, no italic-serif).
{%- endcomment -%}

<section
  class="newsletter-research section section--page-width color-{{ section.settings.color_scheme }}"
  style="
    --newsletter-research-padding-block-start: {{ section.settings['padding-block-start'] }}px;
    --newsletter-research-padding-block-end: {{ section.settings['padding-block-end'] }}px;
  "
>
  <div class="newsletter-research__inner">

    <div class="newsletter-research__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="newsletter-research__eyebrow">
          <span class="newsletter-research__eyebrow-rule" aria-hidden="true"></span>
          <span>{{ section.settings.eyebrow }}</span>
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter-research__heading">{{ section.settings.heading | newline_to_br }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="newsletter-research__body">{{ section.settings.body }}</p>
      {%- endif -%}
    </div>

    <div class="newsletter-research__form-wrap">
      {%- form 'customer', class: 'newsletter-research__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter" />

        <div class="newsletter-research__field">
          <label for="NewsletterEmail-{{ section.id }}" class="visually-hidden">
            {{- section.settings.input_placeholder | default: 'Your email address' -}}
          </label>
          <input
            type="email"
            id="NewsletterEmail-{{ section.id }}"
            name="contact[email]"
            class="newsletter-research__input"
            placeholder="{{ section.settings.input_placeholder | default: 'Your email address' }}"
            autocomplete="email"
            required
          />
          <button type="submit" class="newsletter-research__submit">
            <span>{{ section.settings.submit_label | default: 'Subscribe' }}</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 7H13M13 7L8 2M13 7L8 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        {%- if form.errors -%}
          <p class="newsletter-research__feedback newsletter-research__feedback--error">
            {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
          </p>
        {%- elsif form.posted_successfully? -%}
          <p class="newsletter-research__feedback newsletter-research__feedback--success">
            {{- section.settings.success_message | default: 'Subscribed. Welcome aboard.' -}}
          </p>
        {%- elsif section.settings.reassurance != blank -%}
          <p class="newsletter-research__reassurance">{{ section.settings.reassurance }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>

  </div>
</section>

{% stylesheet %}
  .newsletter-research {
    padding-block-start: var(--newsletter-research-padding-block-start, 96px);
    padding-block-end: var(--newsletter-research-padding-block-end, 96px);
  }

  .newsletter-research__inner {
    width: 85%;
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    column-gap: clamp(2rem, 6vw, 5rem);
    row-gap: 2rem;
    align-items: center;
  }

  /* ── Copy column ── */
  .newsletter-research__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono--family);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    margin: 0 0 1.25rem 0;
  }

  .newsletter-research__eyebrow-rule {
    display: inline-block;
    width: 1.75rem;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }

  .newsletter-research__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-foreground-heading);
    margin: 0;
    max-width: 14ch;
  }

  .newsletter-research__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.9375rem, 1.2vw, 1rem);
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb) / 0.65);
    max-width: 38ch;
    margin: 1.25rem 0 0;
  }

  /* ── Form column ── */
  .newsletter-research__form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    width: 100%;
  }

  .newsletter-research__field {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    width: 100%;
    padding: 0.375rem 0.375rem 0.375rem 1.25rem;
    border-radius: var(--style-border-radius-buttons-primary);
    background: var(--color-background);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .newsletter-research__field:focus-within {
    border-color: rgb(var(--color-foreground-rgb) / 0.6);
    box-shadow: 0 0 0 4px rgb(var(--color-foreground-rgb) / 0.04);
  }

  .newsletter-research__input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    outline: none;
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    color: var(--color-foreground);
    padding-block: 0.625rem;
  }

  .newsletter-research__input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.45);
  }

  .newsletter-research__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border: 0;
    border-radius: var(--style-border-radius-buttons-primary);
    background: var(--color-foreground);
    color: var(--color-background);
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    cursor: pointer;
    transition: opacity 180ms ease;
  }

  .newsletter-research__submit:hover {
    opacity: 0.85;
  }

  .newsletter-research__reassurance,
  .newsletter-research__feedback {
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: rgb(var(--color-foreground-rgb) / 0.5);
    margin: 0.5rem 0 0 1.25rem;
  }

  .newsletter-research__feedback--success {
    color: #009b57;
  }

  .newsletter-research__feedback--error {
    color: #c0392b;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 989px) {
    .newsletter-research__inner {
      grid-template-columns: 1fr;
      row-gap: 2.5rem;
    }
  }

  @media (max-width: 749px) {
    .newsletter-research__inner {
      width: 100%;
      padding-inline: 1.25rem;
    }

    .newsletter-research__field {
      flex-direction: column;
      align-items: stretch;
      gap: 0.625rem;
      padding: 0.75rem;
      border-radius: var(--style-border-radius-buttons-primary);
    }

    .newsletter-research__input {
      padding-inline: 0.625rem;
    }

    .newsletter-research__submit {
      justify-content: center;
      padding: 0.95rem 1.25rem;
    }

    .newsletter-research__reassurance,
    .newsletter-research__feedback {
      margin-inline: 0.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter research",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (mono caps)", "default": "Research updates" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "First to know. First to research." },
    { "type": "textarea", "id": "body", "label": "Supporting body", "default": "New compound releases, COA updates, research protocols, and exclusive pricing — delivered to your inbox. Unsubscribe anytime." },
    { "type": "header", "content": "Form" },
    { "type": "text", "id": "input_placeholder", "label": "Email placeholder", "default": "Your email address" },
    { "type": "text", "id": "submit_label", "label": "Submit button label", "default": "Subscribe" },
    { "type": "text", "id": "reassurance", "label": "Reassurance line", "default": "No spam. Research updates and offers only." },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Subscribed. Welcome aboard." },
    { "type": "header", "content": "Layout" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding-block-start", "label": "Top padding", "min": 0, "max": 200, "step": 8, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom padding", "min": 0, "max": 200, "step": 8, "unit": "px", "default": 96 }
  ],
  "presets": [
    {
      "name": "Newsletter research"
    }
  ]
}
{% endschema %}
