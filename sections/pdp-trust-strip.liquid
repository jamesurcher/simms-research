{%- comment -%}
  PDP trust strip — three-column row between the product info column and
  recommendations. Each item: green accent icon in a soft circle, heading
  and short supporting line. Items are section-level blocks so admins can
  add, remove, or reorder.
{%- endcomment -%}

{%- liquid
  assign items = section.blocks
-%}

<section
  class="pdp-trust-strip section section--page-width"
  style="
    --pdp-trust-strip-padding-block-start: {{ section.settings['padding-block-start'] }}px;
    --pdp-trust-strip-padding-block-end: {{ section.settings['padding-block-end'] }}px;
  "
>
  <div class="pdp-trust-strip__inner">
    <div class="pdp-trust-strip__top-rule" aria-hidden="true"></div>
    {%- if items.size > 0 -%}
      <ul class="pdp-trust-strip__grid" role="list">
        {%- for block in items -%}
          <li class="pdp-trust-strip__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank and block.settings.icon != 'none' -%}
              <span class="pdp-trust-strip__icon-wrap" aria-hidden="true">
                {%- assign icon_file = 'icon-' | append: block.settings.icon | append: '.svg' -%}
                <span class="pdp-trust-strip__icon">{{ icon_file | inline_asset_content }}</span>
              </span>
            {%- endif -%}
            <div class="pdp-trust-strip__text">
              {%- if block.settings.title != blank -%}
                <div class="pdp-trust-strip__title">{{ block.settings.title }}</div>
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <div class="pdp-trust-strip__subtitle">{{ block.settings.subtitle }}</div>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .pdp-trust-strip {
    padding-block-start: var(--pdp-trust-strip-padding-block-start, 48px);
    padding-block-end: var(--pdp-trust-strip-padding-block-end, 48px);
    --pdp-trust-accent: #4d8a5f;
    --pdp-trust-accent-bg: rgb(77 138 95 / 0.1);
  }

  .pdp-trust-strip__inner {
    width: 85%;
    margin-inline: auto;
  }

  .pdp-trust-strip__top-rule {
    height: 1px;
    background: rgb(var(--color-foreground-rgb) / 0.1);
    margin-block-end: 2.5rem;
  }

  .pdp-trust-strip__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
    justify-items: center;
  }

  .pdp-trust-strip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    max-width: 22rem;
  }

  .pdp-trust-strip__icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: var(--pdp-trust-accent-bg);
    color: var(--pdp-trust-accent);
  }

  .pdp-trust-strip__icon {
    display: inline-flex;
    width: 1.125rem;
    height: 1.125rem;
  }

  .pdp-trust-strip__icon svg {
    width: 100%;
    height: 100%;
  }

  .pdp-trust-strip__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .pdp-trust-strip__title {
    font-family: var(--font-body--family);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-foreground);
    line-height: 1.3;
  }

  .pdp-trust-strip__subtitle {
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    line-height: 1.4;
  }

  @media (max-width: 749px) {
    .pdp-trust-strip__inner {
      width: 100%;
      padding-inline: 1.25rem;
    }

    .pdp-trust-strip__top-rule {
      margin-block-end: 1.75rem;
    }

    .pdp-trust-strip__grid {
      gap: 0.75rem;
    }

    .pdp-trust-strip__item {
      gap: 0.5rem;
      max-width: none;
    }

    .pdp-trust-strip__icon-wrap {
      width: 2rem;
      height: 2rem;
    }

    .pdp-trust-strip__icon {
      width: 1rem;
      height: 1rem;
    }

    .pdp-trust-strip__title {
      font-size: 0.8125rem;
    }

    .pdp-trust-strip__subtitle {
      font-size: 0.6875rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "PDP trust strip",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck" },
            { "value": "shield-check", "label": "Shield" },
            { "value": "lock", "label": "Lock" },
            { "value": "zap", "label": "Lightning" },
            { "value": "package", "label": "Package" },
            { "value": "flask-conical", "label": "Flask" },
            { "value": "microscope", "label": "Microscope" },
            { "value": "award", "label": "Award" },
            { "value": "file-text", "label": "Document" },
            { "value": "clipboard-list", "label": "Clipboard" },
            { "value": "gauge", "label": "Gauge" },
            { "value": "qr-code", "label": "QR code" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free shipping"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "on orders over $200"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "PDP trust strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "title": "Free shipping",
            "subtitle": "on orders over $200"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield-check",
            "title": "Damage protection",
            "subtitle": "covered in transit"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "lock",
            "title": "Secure checkout",
            "subtitle": "256-bit SSL"
          }
        }
      ]
    }
  ]
}
{% endschema %}
