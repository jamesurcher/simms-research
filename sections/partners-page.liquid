{% liquid
  assign apply_url = section.settings.apply_url | default: 'mailto:support@simmsresearch.com?subject=Research%20Partners%20Application'
  assign secondary_url = section.settings.secondary_url | default: '/pages/contact'
%}

<section class="partners-page color-{{ section.settings.color_scheme }}">
  <div class="partners-page__shell">
    <header class="partners-page__hero">
      <p class="partners-page__eyebrow">{{ section.settings.hero_eyebrow }}</p>
      <h1 class="partners-page__title">{{ section.settings.hero_heading }}</h1>
      <div class="partners-page__subhead">
        {{ section.settings.hero_subhead }}
      </div>
      <div class="partners-page__actions">
        <a class="button partners-page__button" href="{{ apply_url }}">
          {{ section.settings.hero_button_label }}
          <span aria-hidden="true">→</span>
        </a>
        <a class="partners-page__secondary" href="{{ secondary_url }}">
          {{ section.settings.secondary_label }}
        </a>
      </div>
      <p class="partners-page__micro">{{ section.settings.hero_microcopy }}</p>
    </header>

    <div class="partners-page__stats" aria-label="Partner program highlights">
      <div class="partners-page__stat">
        <p>{{ section.settings.stat_1_value }}</p>
        <span>{{ section.settings.stat_1_label }}</span>
      </div>
      <div class="partners-page__stat">
        <p>{{ section.settings.stat_2_value }}</p>
        <span>{{ section.settings.stat_2_label }}</span>
      </div>
      <div class="partners-page__stat">
        <p>{{ section.settings.stat_3_value }}</p>
        <span>{{ section.settings.stat_3_label }}</span>
      </div>
      <div class="partners-page__stat">
        <p>{{ section.settings.stat_4_value }}</p>
        <span>{{ section.settings.stat_4_label }}</span>
      </div>
    </div>

    <section class="partners-page__section" aria-labelledby="PartnersHowItWorks">
      <p class="partners-page__eyebrow">{{ section.settings.steps_eyebrow }}</p>
      <h2 id="PartnersHowItWorks" class="partners-page__section-title">{{ section.settings.steps_heading }}</h2>
      <div class="partners-page__steps">
        <article class="partners-page__step">
          <p class="partners-page__step-number">01</p>
          <h3>{{ section.settings.step_1_title }}</h3>
          <p>{{ section.settings.step_1_body }}</p>
        </article>
        <article class="partners-page__step">
          <p class="partners-page__step-number">02</p>
          <h3>{{ section.settings.step_2_title }}</h3>
          <p>{{ section.settings.step_2_body }}</p>
        </article>
        <article class="partners-page__step">
          <p class="partners-page__step-number">03</p>
          <h3>{{ section.settings.step_3_title }}</h3>
          <p>{{ section.settings.step_3_body }}</p>
        </article>
        <article class="partners-page__step">
          <p class="partners-page__step-number">04</p>
          <h3>{{ section.settings.step_4_title }}</h3>
          <p>{{ section.settings.step_4_body }}</p>
        </article>
      </div>
    </section>

    <section class="partners-page__section" aria-labelledby="PartnersBenefits">
      <p class="partners-page__eyebrow">{{ section.settings.benefits_eyebrow }}</p>
      <h2 id="PartnersBenefits" class="partners-page__section-title">{{ section.settings.benefits_heading }}</h2>
      <div class="partners-page__benefits">
        <article class="partners-page__card">
          <h3>{{ section.settings.benefit_1_title }}</h3>
          <p>{{ section.settings.benefit_1_body }}</p>
        </article>
        <article class="partners-page__card">
          <h3>{{ section.settings.benefit_2_title }}</h3>
          <p>{{ section.settings.benefit_2_body }}</p>
        </article>
        <article class="partners-page__card">
          <h3>{{ section.settings.benefit_3_title }}</h3>
          <p>{{ section.settings.benefit_3_body }}</p>
        </article>
        <article class="partners-page__card">
          <h3>{{ section.settings.benefit_4_title }}</h3>
          <p>{{ section.settings.benefit_4_body }}</p>
        </article>
        <article class="partners-page__card">
          <h3>{{ section.settings.benefit_5_title }}</h3>
          <p>{{ section.settings.benefit_5_body }}</p>
        </article>
        <article class="partners-page__card">
          <h3>{{ section.settings.benefit_6_title }}</h3>
          <p>{{ section.settings.benefit_6_body }}</p>
        </article>
      </div>
    </section>

    <section class="partners-page__section partners-page__section--faq" aria-labelledby="PartnersFaq">
      <p class="partners-page__eyebrow">{{ section.settings.faq_eyebrow }}</p>
      <h2 id="PartnersFaq" class="partners-page__section-title">{{ section.settings.faq_heading }}</h2>
      <div class="partners-page__faq">
        {% for block in section.blocks %}
          <details class="partners-page__faq-item" {{ block.shopify_attributes }}>
            <summary>
              <span aria-hidden="true">›</span>
              {{ block.settings.question }}
            </summary>
            <div class="partners-page__faq-answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endfor %}
      </div>
    </section>

    <section class="partners-page__final-cta" aria-label="Apply to the research partner program">
      <p class="partners-page__eyebrow">{{ section.settings.cta_eyebrow }}</p>
      <h2>{{ section.settings.cta_heading }}</h2>
      <div class="partners-page__cta-copy">
        {{ section.settings.cta_body }}
      </div>
      <a class="button partners-page__button" href="{{ apply_url }}">
        {{ section.settings.cta_button_label }}
        <span aria-hidden="true">→</span>
      </a>
    </section>
  </div>
</section>

{% stylesheet %}
  .partners-page {
    padding-block: clamp(3rem, 6vw, 5.5rem);
    background:
      radial-gradient(circle at 50% 0%, rgb(var(--color-foreground-rgb) / 0.035), transparent 28rem),
      rgb(var(--color-background-rgb));
  }

  .partners-page__shell {
    width: min(100% - 2rem, 85rem);
    margin-inline: auto;
  }

  @media screen and (min-width: 750px) {
    .partners-page__shell {
      width: min(72.25vw, 85rem);
    }
  }

  .partners-page__hero {
    display: grid;
    justify-items: center;
    max-width: 48rem;
    min-height: clamp(22rem, 42vw, 33rem);
    margin-inline: auto;
    padding-block: clamp(3rem, 6vw, 5.5rem);
    text-align: center;
  }

  .partners-page__eyebrow,
  .partners-page__micro,
  .partners-page__stat span,
  .partners-page__step h3,
  .partners-page__card h3,
  .partners-page__faq summary {
    font-family: var(--font-mono--family);
    font-weight: var(--font-mono--weight);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .partners-page__eyebrow {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.48);
    font-size: 0.75rem;
    line-height: 1.2;
  }

  .partners-page__title {
    max-width: 46rem;
    margin: 1.2rem 0 0;
    font-size: clamp(2.9rem, 5.8vw, 5.4rem);
    letter-spacing: -0.07em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .partners-page__subhead {
    max-width: 40rem;
    margin-block-start: 1.25rem;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-size: clamp(1.05rem, 1.55vw, 1.35rem);
    line-height: 1.45;
  }

  .partners-page__subhead p,
  .partners-page__cta-copy p {
    margin: 0;
  }

  .partners-page__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-block-start: 1.75rem;
  }

  .partners-page__button {
    min-width: 12.5rem;
    min-height: 3.6rem;
    border-radius: 999px;
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
  }

  .partners-page__button:hover {
    background: var(--color-primary-button-hover-background);
    border-color: var(--color-primary-button-hover-border);
    color: var(--color-primary-button-hover-text);
  }

  .partners-page__button span {
    margin-inline-start: 0.7rem;
  }

  .partners-page__secondary {
    color: rgb(var(--color-foreground-rgb) / 0.62);
    font-size: 0.9375rem;
    text-decoration: underline;
    text-underline-offset: 0.28em;
  }

  .partners-page__secondary:hover {
    color: var(--color-foreground);
  }

  .partners-page__micro {
    margin: 1.4rem 0 0;
    color: rgb(var(--color-foreground-rgb) / 0.34);
    font-size: 0.6875rem;
    line-height: 1.2;
  }

  .partners-page__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-block: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .partners-page__stat {
    display: grid;
    justify-items: center;
    gap: 0.6rem;
    padding: clamp(1.4rem, 3vw, 2.25rem) 1rem;
    text-align: center;
  }

  .partners-page__stat + .partners-page__stat {
    border-inline-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .partners-page__stat p {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.82);
    font-family: var(--font-mono--family);
    font-size: clamp(2rem, 3vw, 2.8rem);
    line-height: 0.95;
  }

  .partners-page__stat span {
    color: rgb(var(--color-foreground-rgb) / 0.42);
    font-size: 0.6875rem;
    line-height: 1.2;
  }

  .partners-page__section {
    padding-block: clamp(3.5rem, 7vw, 6rem);
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .partners-page__section-title {
    max-width: 60rem;
    margin: 1rem auto 0;
    font-size: clamp(2.15rem, 4.1vw, 4.2rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-align: center;
    text-transform: uppercase;
  }

  .partners-page__section > .partners-page__eyebrow {
    text-align: center;
  }

  .partners-page__steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2.2rem);
    margin-block-start: clamp(2.2rem, 4.5vw, 3.75rem);
  }

  .partners-page__step {
    display: grid;
    gap: 0.75rem;
    padding-block-start: 1rem;
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .partners-page__step-number {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.18);
    font-family: var(--font-mono--family);
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 0.9;
  }

  .partners-page__step h3,
  .partners-page__card h3 {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.86);
    font-size: 0.875rem;
    line-height: 1.35;
  }

  .partners-page__step p:last-child,
  .partners-page__card p,
  .partners-page__faq-answer {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.56);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .partners-page__benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
    margin-block-start: clamp(2.2rem, 4.5vw, 3.75rem);
  }

  .partners-page__card,
  .partners-page__final-cta {
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 18px;
    background:
      linear-gradient(rgb(var(--color-foreground-rgb) / 0.028), rgb(var(--color-foreground-rgb) / 0.028)),
      rgb(var(--color-background-rgb));
  }

  .partners-page__card {
    display: grid;
    gap: 1rem;
    min-height: 12rem;
    padding: clamp(1.25rem, 2.5vw, 1.8rem);
  }

  .partners-page__section--faq {
    border-block-end: 0;
  }

  .partners-page__faq {
    max-width: 58rem;
    margin: clamp(2.2rem, 4vw, 3.5rem) auto 0;
  }

  .partners-page__faq-item {
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .partners-page__faq-item:last-child {
    border-block-end: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .partners-page__faq summary {
    display: flex;
    gap: 1.1rem;
    padding-block: 1.45rem;
    color: rgb(var(--color-foreground-rgb) / 0.86);
    cursor: pointer;
    font-size: 0.875rem;
    line-height: 1.35;
    list-style: none;
  }

  .partners-page__faq summary::-webkit-details-marker {
    display: none;
  }

  .partners-page__faq summary span {
    color: rgb(var(--color-foreground-rgb) / 0.42);
    transition: transform 180ms ease;
  }

  .partners-page__faq-item[open] summary span {
    transform: rotate(90deg);
  }

  .partners-page__faq-answer {
    max-width: 48rem;
    padding: 0 0 1.45rem 2rem;
  }

  .partners-page__final-cta {
    display: grid;
    justify-items: center;
    gap: 1.3rem;
    max-width: 58rem;
    margin: clamp(3.5rem, 7vw, 6rem) auto 0;
    padding: clamp(1.75rem, 4vw, 3rem);
    text-align: center;
  }

  .partners-page__final-cta h2 {
    max-width: 42rem;
    margin: 0;
    font-size: clamp(2rem, 4vw, 4rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .partners-page__cta-copy {
    max-width: 38rem;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.45;
  }

  @media screen and (max-width: 989px) {
    .partners-page__stats,
    .partners-page__steps,
    .partners-page__benefits {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .partners-page__stat:nth-child(3) {
      border-inline-start: 0;
      border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    }

    .partners-page__stat:nth-child(4) {
      border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    }
  }

  @media screen and (max-width: 749px) {
    .partners-page {
      padding-block: 2.5rem 4rem;
    }

    .partners-page__hero {
      min-height: auto;
      padding-block: 2.75rem 4rem;
    }

    .partners-page__title {
      font-size: clamp(2.6rem, 12vw, 3.8rem);
    }

    .partners-page__stats,
    .partners-page__steps,
    .partners-page__benefits {
      grid-template-columns: 1fr;
    }

    .partners-page__stat + .partners-page__stat,
    .partners-page__stat:nth-child(3),
    .partners-page__stat:nth-child(4) {
      border-inline-start: 0;
      border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    }

    .partners-page__actions {
      align-items: stretch;
      flex-direction: column;
      width: 100%;
    }
  }
{% endstylesheet %}

