{% comment %}
  Inline collection search + sort.
  Client-side title filtering against existing rendered cards.
  Sort delegates to Shopify via ?sort_by= URL param.
{% endcomment %}

<collection-filter
  class="collection-filter color-{{ section.settings.color_scheme }}"
  data-grid-selector="results-list"
  data-card-selector="li.product-grid__item"
  data-total-count="{{ collection.products_count }}"
  style="
    --collection-filter-padding-block-start: {{ section.settings['padding-block-start'] }}px;
    --collection-filter-padding-block-end: {{ section.settings['padding-block-end'] }}px;
  "
>
  <div class="collection-filter__inner">
    <div class="collection-filter__row">
      <label class="collection-filter__search">
        <svg
          class="collection-filter__search-icon"
          width="18"
          height="18"
          viewBox="0 0 18 18"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.4"/>
          <line x1="12.4" y1="12" x2="16" y2="15.6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        <input
          type="search"
          placeholder="Search products..."
          autocomplete="off"
          data-search-input
          aria-label="Search products"
        />
        <button
          type="button"
          class="collection-filter__clear"
          data-search-clear
          hidden
          aria-label="Clear search"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <line x1="3" y1="3" x2="11" y2="11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <line x1="11" y1="3" x2="3" y2="11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </button>
      </label>
      <label class="collection-filter__sort">
        <span class="visually-hidden">Sort by</span>
        <select data-sort-select aria-label="Sort by">
          <option value="manual">Featured</option>
          <option value="title-ascending">A–Z</option>
          <option value="title-descending">Z–A</option>
          <option value="price-ascending">Price: Low to High</option>
          <option value="price-descending">Price: High to Low</option>
        </select>
        <svg
          class="collection-filter__sort-chevron"
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          aria-hidden="true"
        >
          <polyline
            points="3,5 6,8 9,5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
      </label>
    </div>
    <p class="collection-filter__status" data-status>
      Showing {{ collection.products_count }} of {{ collection.products_count }} products
    </p>
  </div>
</collection-filter>

<script src="{{ 'collection-filter.js' | asset_url }}" defer></script>

{% stylesheet %}
  collection-filter {
    display: block;
    padding-block-start: var(--collection-filter-padding-block-start, 0);
    padding-block-end: var(--collection-filter-padding-block-end, 0);
  }

  .collection-filter__inner {
    max-width: var(--page-content-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .collection-filter__row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
    max-width: 700px;
  }

  .collection-filter__search {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    border-radius: 15px;
    padding: 0 0.75rem;
    gap: 0.5rem;
    transition: border-color 150ms ease;
  }

  .collection-filter__search:focus-within {
    border-color: rgb(var(--color-foreground-rgb) / 0.5);
  }

  .collection-filter__search-icon {
    flex-shrink: 0;
    opacity: 0.55;
  }

  .collection-filter__search input[type='search'] {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    padding: 0.5rem 0;
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    color: var(--color-foreground);
    min-width: 0;
  }

  .collection-filter__search input::placeholder {
    color: rgb(var(--color-foreground-rgb) / 0.4);
  }

  .collection-filter__search input::-webkit-search-cancel-button {
    appearance: none;
    -webkit-appearance: none;
  }

  .collection-filter__clear {
    background: transparent;
    border: 0;
    cursor: pointer;
    color: rgb(var(--color-foreground-rgb) / 0.55);
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
  }

  .collection-filter__clear:hover {
    color: var(--color-foreground);
  }

  .collection-filter__sort {
    position: relative;
    display: flex;
    align-items: center;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.15);
    border-radius: 15px;
    padding: 0 2rem 0 0.875rem;
    flex-shrink: 0;
  }

  .collection-filter__sort select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: 0;
    outline: 0;
    padding: 0.5rem 0;
    font-family: var(--font-body--family);
    font-size: 0.875rem;
    color: var(--color-foreground);
    cursor: pointer;
  }

  .collection-filter__sort-chevron {
    position: absolute;
    right: 0.75rem;
    pointer-events: none;
    opacity: 0.55;
  }

  .collection-filter__status {
    margin-block-start: 1rem;
    margin-block-end: 0;
    font-family: var(--font-body--family);
    font-size: 0.8125rem;
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }

  @media (max-width: 749px) {
    .collection-filter__row {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection filter",
  "tag": "section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection filter"
    }
  ]
}
{% endschema %}
