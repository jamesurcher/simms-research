      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Raw material sourcing"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Peptides sourced from US-licensed manufacturers with documented synthesis chains."
        }
      ]
    },
    {
      "type": "commitment",
      "name": "Commitment",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "No proprietary blends"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Every product is a single compound at a stated concentration. No blends, no ambiguity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About / Quality"
    }
  ]
}
{% endschema %}
