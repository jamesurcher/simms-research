{% liquid
  assign contact_url = section.settings.contact_url | default: '/pages/contact'
%}

<section class="faq-page color-{{ section.settings.color_scheme }}">
  <div class="faq-page__shell">
    <header class="faq-page__hero">
      <p class="faq-page__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="faq-page__title">{{ section.settings.heading }}</h1>
      <div class="faq-page__intro">
        {{ section.settings.intro }}
      </div>
    </header>

    <div class="faq-page__groups">
      <section class="faq-page__group" aria-labelledby="FaqGeneral">
        <div class="faq-page__group-header">
          <span class="faq-page__group-mark" aria-hidden="true">?</span>
          <h2 id="FaqGeneral">{{ section.settings.general_heading }}</h2>
        </div>
        <div class="faq-page__items">
          {% for block in section.blocks %}
            {% if block.settings.category == 'general' %}
              <details class="faq-page__item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="faq-page__chevron" aria-hidden="true">v</span>
                </summary>
                <div class="faq-page__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="faq-page__group" aria-labelledby="FaqQuality">
        <div class="faq-page__group-header">
          <span class="faq-page__group-mark" aria-hidden="true">T</span>
          <h2 id="FaqQuality">{{ section.settings.quality_heading }}</h2>
        </div>
        <div class="faq-page__items">
          {% for block in section.blocks %}
            {% if block.settings.category == 'quality' %}
              <details class="faq-page__item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="faq-page__chevron" aria-hidden="true">v</span>
                </summary>
                <div class="faq-page__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="faq-page__group" aria-labelledby="FaqShipping">
        <div class="faq-page__group-header">
          <span class="faq-page__group-mark" aria-hidden="true">S</span>
          <h2 id="FaqShipping">{{ section.settings.shipping_heading }}</h2>
        </div>
        <div class="faq-page__items">
          {% for block in section.blocks %}
            {% if block.settings.category == 'shipping' %}
              <details class="faq-page__item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="faq-page__chevron" aria-hidden="true">v</span>
                </summary>
                <div class="faq-page__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="faq-page__group" aria-labelledby="FaqOrders">
        <div class="faq-page__group-header">
          <span class="faq-page__group-mark" aria-hidden="true">$</span>
          <h2 id="FaqOrders">{{ section.settings.orders_heading }}</h2>
        </div>
        <div class="faq-page__items">
          {% for block in section.blocks %}
            {% if block.settings.category == 'orders' %}
              <details class="faq-page__item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="faq-page__chevron" aria-hidden="true">v</span>
                </summary>
                <div class="faq-page__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="faq-page__group" aria-labelledby="FaqReturns">
        <div class="faq-page__group-header">
          <span class="faq-page__group-mark" aria-hidden="true">!</span>
          <h2 id="FaqReturns">{{ section.settings.returns_heading }}</h2>
        </div>
        <div class="faq-page__items">
          {% for block in section.blocks %}
            {% if block.settings.category == 'returns' %}
              <details class="faq-page__item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="faq-page__chevron" aria-hidden="true">v</span>
                </summary>
                <div class="faq-page__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </section>

      <section class="faq-page__group" aria-labelledby="FaqCompliance">
        <div class="faq-page__group-header">
          <span class="faq-page__group-mark" aria-hidden="true">R</span>
          <h2 id="FaqCompliance">{{ section.settings.compliance_heading }}</h2>
        </div>
        <div class="faq-page__items">
          {% for block in section.blocks %}
            {% if block.settings.category == 'compliance' %}
              <details class="faq-page__item" {{ block.shopify_attributes }}>
                <summary>
                  <span>{{ block.settings.question }}</span>
                  <span class="faq-page__chevron" aria-hidden="true">v</span>
                </summary>
                <div class="faq-page__answer">
                  {{ block.settings.answer }}
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </section>
    </div>

    <section class="faq-page__cta" aria-label="Contact support">
      <p class="faq-page__eyebrow">{{ section.settings.cta_eyebrow }}</p>
      <h2>{{ section.settings.cta_heading }}</h2>
      <div class="faq-page__cta-copy">
        {{ section.settings.cta_body }}
      </div>
      <a class="button faq-page__button" href="{{ contact_url }}">
        {{ section.settings.cta_button_label }}
      </a>
    </section>
  </div>
</section>

{% stylesheet %}
  .faq-page {
    padding-block: clamp(3rem, 6vw, 6rem);
    background:
      radial-gradient(circle at 50% 0%, rgb(var(--color-foreground-rgb) / 0.035), transparent 28rem),
      rgb(var(--color-background-rgb));
  }

  .faq-page__shell {
    width: min(100% - 2rem, 85rem);
    margin-inline: auto;
  }

  @media screen and (min-width: 750px) {
    .faq-page__shell {
      width: min(72.25vw, 85rem);
    }
  }

  .faq-page__hero {
    display: grid;
    justify-items: center;
    max-width: 48rem;
    margin-inline: auto;
    padding-block: clamp(3rem, 6vw, 5.5rem);
    text-align: center;
  }

  .faq-page__eyebrow,
  .faq-page__group h2,
  .faq-page__item summary,
  .faq-page__group-mark {
    font-family: var(--font-mono--family);
    font-weight: var(--font-mono--weight);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .faq-page__eyebrow {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.48);
    font-size: 0.75rem;
    line-height: 1.2;
  }

  .faq-page__title {
    max-width: 44rem;
    margin: 1.15rem 0 0;
    font-size: clamp(2.9rem, 5.8vw, 5.4rem);
    letter-spacing: -0.07em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .faq-page__intro {
    max-width: 42rem;
    margin-block-start: 1.25rem;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-size: clamp(1.05rem, 1.55vw, 1.3rem);
    line-height: 1.45;
  }

  .faq-page__intro p,
  .faq-page__cta-copy p {
    margin: 0;
  }

  .faq-page__groups {
    display: grid;
    gap: clamp(1.35rem, 2.5vw, 2rem);
    max-width: 64rem;
    margin-inline: auto;
  }

  .faq-page__group,
  .faq-page__cta {
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 18px;
    background:
      linear-gradient(rgb(var(--color-foreground-rgb) / 0.028), rgb(var(--color-foreground-rgb) / 0.028)),
      rgb(var(--color-background-rgb));
  }

  .faq-page__group {
    padding: clamp(1.25rem, 2.5vw, 1.8rem);
  }

  .faq-page__group-header {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-block-end: 1.25rem;
  }

  .faq-page__group-mark {
    display: grid;
    width: 2.6rem;
    height: 2.6rem;
    place-items: center;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: 0.65rem;
    background: rgb(var(--color-foreground-rgb) / 0.04);
    color: rgb(var(--color-foreground-rgb) / 0.7);
    font-size: 0.9rem;
    letter-spacing: 0;
  }

  .faq-page__group h2 {
    margin: 0;
    color: rgb(var(--color-foreground-rgb) / 0.86);
    font-size: 1rem;
    line-height: 1.25;
    letter-spacing: 0.08em;
  }

  .faq-page__item {
    border-block-start: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
  }

  .faq-page__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
    color: rgb(var(--color-foreground-rgb) / 0.84);
    cursor: pointer;
    font-size: 0.875rem;
    line-height: 1.4;
    list-style: none;
  }

  .faq-page__item summary::-webkit-details-marker {
    display: none;
  }

  .faq-page__chevron {
    flex: 0 0 auto;
    color: rgb(var(--color-foreground-rgb) / 0.48);
    font-size: 1rem;
    transition: transform 180ms ease;
  }

  .faq-page__item[open] .faq-page__chevron {
    transform: rotate(180deg);
  }

  .faq-page__answer {
    max-width: 52rem;
    padding-block: 0 1.15rem;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .faq-page__cta {
    display: grid;
    justify-items: center;
    gap: 1rem;
    max-width: 64rem;
    margin: clamp(2.5rem, 5vw, 4rem) auto 0;
    padding: clamp(1.75rem, 4vw, 3rem);
    text-align: center;
  }

  .faq-page__cta h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 4rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .faq-page__cta-copy {
    max-width: 36rem;
    color: rgb(var(--color-foreground-rgb) / 0.58);
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    line-height: 1.45;
  }

  .faq-page__button {
    min-width: 12.5rem;
    min-height: 3.6rem;
    border-radius: 999px;
    background: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
  }

  .faq-page__button:hover {
    background: var(--color-primary-button-hover-background);
    border-color: var(--color-primary-button-hover-border);
    color: var(--color-primary-button-hover-text);
  }

  @media screen and (max-width: 749px) {
    .faq-page {
      padding-block: 2.5rem 4rem;
    }

    .faq-page__hero {
      padding-block: 2.75rem 4rem;
    }

    .faq-page__title {
      font-size: clamp(2.6rem, 12vw, 3.8rem);
    }

    .faq-page__group {
      padding: 1.1rem;
    }

    .faq-page__group-header {
      align-items: flex-start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ page",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Find answers to common questions about research compounds, shipping, lab testing, and policies.</p>"
    },
    {
      "type": "header",
      "content": "Groups"
    },
    {
      "type": "text",
      "id": "general_heading",
      "label": "General heading",
      "default": "General"
    },
    {
      "type": "text",
      "id": "quality_heading",
      "label": "Quality heading",
      "default": "Quality & Testing"
    },
    {
      "type": "text",
      "id": "shipping_heading",
      "label": "Shipping heading",
      "default": "Shipping & Delivery"
    },
    {
      "type": "text",
      "id": "orders_heading",
      "label": "Orders heading",
      "default": "Orders & Payment"
    },
    {
      "type": "text",
      "id": "returns_heading",
      "label": "Returns heading",
      "default": "Returns & Issues"
    },
    {
      "type": "text",
      "id": "compliance_heading",
      "label": "Compliance heading",
      "default": "Research Use & Compliance"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "CTA eyebrow",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA heading",
      "default": "Still have questions?"
    },
    {
      "type": "richtext",
      "id": "cta_body",
      "label": "CTA body",
      "default": "<p>Send us a message and we will route it to the right place.</p>"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "CTA button label",
      "default": "Contact Support"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact URL"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            {
              "value": "general",
              "label": "General"
            },
            {
              "value": "quality",
              "label": "Quality & Testing"
            },
            {
              "value": "shipping",
              "label": "Shipping & Delivery"
            },
            {
              "value": "orders",
              "label": "Orders & Payment"
            },
            {
              "value": "returns",
              "label": "Returns & Issues"
            },
            {
              "value": "compliance",
              "label": "Research Use & Compliance"
            }
          ],
          "default": "general"
        },
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ page"
    }
  ]
}
{% endschema %}
